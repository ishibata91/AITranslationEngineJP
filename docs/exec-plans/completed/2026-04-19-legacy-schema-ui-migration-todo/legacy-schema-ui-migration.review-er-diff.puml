@startuml

title legacy master schema ER review diff

top to bottom direction
hide methods
skinparam classAttributeIconSize 0
skinparam nodesep 80
skinparam ranksep 90
skinparam packageStyle rectangle
skinparam shadowing false

skinparam class {
    BackgroundColor<<existing>> #F7F9FC
    BorderColor<<existing>> #546E7A
    FontColor<<existing>> #243447
    BackgroundColor<<added>> #EEF9EF
    BorderColor<<added>> #2E7D32
    FontColor<<added>> #1B5E20
    BackgroundColor<<removed>> #FFF1F1
    BorderColor<<removed>> #C62828
    FontColor<<removed>> #7F1D1D
    BackgroundColor<<changed>> #FFF8E1
    BorderColor<<changed>> #F9A825
    FontColor<<changed>> #4E342E
    BackgroundColor<<risk>> #F4F7FA
    BorderColor<<risk>> #607D8B
    FontColor<<risk>> #1F2933
}

legend bottom right
    |= Style |= Meaning |
    |<#F7F9FC> existing | unchanged source of truth |
    |<#EEF9EF> added | new element or new route |
    |<#FFF1F1> removed | deleted or retired element |
    |<#FFF8E1> changed | behavior or responsibility changed |
    |<#F4F7FA> risk | review note, constraint, or split reason |
endlegend

package "drop: legacy master tables" as DropLegacyTables {
    class "master_dictionary_entries" as LegacyDictionary <<removed>> {
        master_dictionary_entries
    }

    class "master_persona_entries" as LegacyPersona <<removed>> {
        master_persona_entries
    }

    class "master_persona_ai_settings" as LegacyAISettings <<removed>> {
        master_persona_ai_settings
    }

    class "master_persona_run_status" as LegacyRunStatus <<removed>> {
        master_persona_run_status
        no replacement table
    }
}

package "keep: canonical foundation tables" as KeepCanonicalTables {
    class "dictionary foundation" as CanonicalDictionary <<existing>> {
        DICTIONARY_ENTRY
        XTRANSLATOR_TRANSLATION_XML
        dedupe key uses trimmed source_term
        and translated_term exact match
    }

    class "persona foundation" as CanonicalPersona <<existing>> {
        PERSONA
        NPC_PROFILE
        NPC_RECORD
    }
}

package "add: settings table" as AddSettingsTable {
    class "PERSONA_GENERATION_SETTINGS" as PersonaGenerationSettings <<added>> {
        PERSONA_GENERATION_SETTINGS
        id = 1
        provider
        model
    }
}

LegacyDictionary -[#C62828,dashed]-> CanonicalDictionary : replace with canonical dictionary ER
LegacyPersona -[#C62828,dashed]-> CanonicalPersona : replace with canonical persona ER
LegacyAISettings -[#2E7D32,dashed]-> PersonaGenerationSettings : replace settings table

note bottom of DropLegacyTables
    drop without legacy backfill
    run status is dropped without replacement
end note

note bottom of AddSettingsTable
    settings are outside PERSONA and DICTIONARY_ENTRY
    run state is in UI memory only
    restart returns to JSON unselected state
    JSON is selected manually before preview
    partial persona rows are not persisted
end note

@enduml
