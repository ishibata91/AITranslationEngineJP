vars: {
  d2-config: {
    theme-id: 201
  }
}

direction: down

title: "dashboard-and-app-shell frontend component detail"

frontend_shell_detail: {
  label: "dashboard-and-app-shell component detail"
  direction: down
  style.stroke: "#2e7d32"
  style.stroke-width: 2
  style.fill: "#f7fff7"
  style.font-color: "#1b5e20"

  view_package: {
    label: "package: View"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    shell_entry: {
      shape: class
      label: "App entry"
      +actual: App.svelte
      +shellState: ShellState
      +createShellState(): void
      +renderShell(): void
    }

    shell_frame: {
      shape: class
      label: "App shell"
      +actual: AppShell.svelte
      +renderHeader(): void
      +renderNavigation(): void
      +renderRouteView(): RouteView
    }

    route_views: {
      label: "package: Route Views"
      direction: down
      style.stroke: "#2e7d32"
      style.stroke-dash: 4
      style.fill: "#f4fbf4"
      style.font-color: "#1b5e20"

      dashboard_view: {
        shape: class
        label: "Dashboard view"
        +routeId: dashboard
        +entryCards: five cards
        +openDestination(route): void
      }

      master_dictionary_view: {
        shape: class
        label: "Master dictionary view"
        +routeId: master_dictionary
        +pageLabel: "マスター辞書"
        +renderImportAndList(): void
        +keepStateInsidePage(): void
      }

      placeholder_view: {
        shape: class
        label: "Placeholder view"
        +statusText: "準備中"
        +renderRemainingRoutes(): void
      }
    }

    navigation_surface: {
      shape: class
      label: "Navigation surface"
      +destinations: five routes
      +activeRoute: RouteId
      +currentLocation: string
      +selectDestination(route): void
    }
  }

  store_package: {
    label: "package: Store"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    shell_state: {
      shape: class
      label: "Shell state"
      +actual: shell-state.ts
      +routeOrder: RouteId list
      +currentRoute: dashboard
      +currentPageLabel: string
      +currentLocationLabel: string
      +placeholderStatus: string
      +navigate(route): void
      +getRouteMeta(route): RouteMeta
    }
  }

  view_package.shell_entry -> store_package.shell_state: "shell state を生成"
  view_package.shell_entry -> view_package.shell_frame: "shellState を渡す"
  store_package.shell_state -> view_package.shell_frame: "現在地と描画条件"

  view_package.shell_frame -> view_package.navigation_surface: "header / nav を描画"
  view_package.shell_frame -> view_package.route_views.dashboard_view: "dashboard route"
  view_package.shell_frame -> view_package.route_views.master_dictionary_view: "master_dictionary route"
  view_package.shell_frame -> view_package.route_views.placeholder_view: "remaining routes"

  view_package.navigation_surface -> store_package.shell_state: "navigate(route)"
  view_package.route_views.dashboard_view -> store_package.shell_state: "openDestination(route)"

  store_package.shell_state -> view_package.navigation_surface: "activeRoute / currentLocation" {
    style.stroke-dash: 4
  }
  store_package.shell_state -> view_package.route_views.dashboard_view: "entryCards / activeRoute" {
    style.stroke-dash: 4
  }
  store_package.shell_state -> view_package.route_views.master_dictionary_view: "activeRoute / pageLabel" {
    style.stroke-dash: 4
  }
  store_package.shell_state -> view_package.route_views.placeholder_view: "pageLabel / placeholderStatus" {
    style.stroke-dash: 4
  }
}

style: {
  font-size: 20
}

edge: {
  style.font-size: 18
}
