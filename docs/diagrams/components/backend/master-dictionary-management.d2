vars: {
  d2-config: {
    theme-id: 201
  }
}

direction: down

title: "master-dictionary-management backend component detail"

backend_master_dictionary_detail: {
  label: "master-dictionary-management backend component detail"
  direction: down
  style.stroke: "#2e7d32"
  style.stroke-width: 2
  style.fill: "#f7fff7"
  style.font-color: "#1b5e20"

  bootstrap_package: {
    label: "package: Bootstrap"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    composition_root: {
      shape: class
      label: "AppController composition root"
      +wireController(): MasterDictionaryController
      +wireUsecase(): MasterDictionaryUsecase
      +wireServices(): Query/Command/Import Services
      +wireAdapters(): Repository/XML/Wails adapters
    }
  }

  controller_package: {
    label: "package: Controller"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    dictionary_controller: {
      shape: class
      label: "Wails controller"
      +MasterDictionaryGetPage(request)
      +MasterDictionaryGetDetail(entryId)
      +MasterDictionaryCreate(draft)
      +MasterDictionaryUpdate(entryId, draft)
      +MasterDictionaryDelete(entryId)
      +MasterDictionaryImportXML(filePath)
    }

    usecase_port: {
      shape: class
      label: "caller-owned UsecasePort"
      +GetPage(query)
      +GetEntry(entryId)
      +CreateEntry(input)
      +UpdateEntry(input)
      +DeleteEntry(input)
      +ImportXML(input)
    }
  }

  usecase_package: {
    label: "package: UseCase"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    master_dictionary_usecase: {
      shape: class
      label: "MasterDictionaryUsecase"
      +GetPage(query)
      +GetEntry(entryId)
      +CreateEntry(input)
      +UpdateEntry(input)
      +DeleteEntry(input)
      +ImportXML(input)
    }

    service_ports: {
      shape: class
      label: "caller-owned service ports"
      +QueryServicePort
      +CommandServicePort
      +ImportServicePort
      +RuntimeEventPublisherPort
    }
  }

  service_package: {
    label: "package: Service"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    query_service: {
      shape: class
      label: "Query service"
      +SearchEntries(query)
      +LoadEntryDetail(entryId)
    }

    command_service: {
      shape: class
      label: "Command service"
      +CreateEntry(input)
      +UpdateEntry(input)
      +DeleteEntry(input)
    }

    import_service: {
      shape: class
      label: "Import service"
      +ImportXML(input)
      +emitImportProgress(progress)
    }

    service_ports_owned: {
      shape: class
      label: "caller-owned adapter ports"
      +RepositoryPort
      +XMLFilePort
      +XMLRecordReaderPort
      +RuntimeContextPort
    }
  }

  adapter_package: {
    label: "package: Adapter"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    repository_adapter: {
      shape: class
      label: "repository adapter"
      +List(query)
      +GetByID(entryId)
      +Create(entry)
      +Update(entry)
      +Delete(entryId)
      +UpsertBySourceAndREC(entry)
    }

    xml_file_adapter: {
      shape: class
      label: "filesystem / XML file adapter"
      +ResolvePath(filePath)
      +Open(filePath)
    }

    xml_record_reader_adapter: {
      shape: class
      label: "XML record reader adapter"
      +CountStringRecords(reader)
      +ReadStringRecords(reader)
    }

    runtime_event_adapter: {
      shape: class
      label: "Wails runtime adapter"
      +PublishImportProgress(payload)
      +PublishImportCompleted(payload)
    }
  }

  testing_boundary: {
    label: "test boundary"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    upper_unit_tests: {
      shape: class
      label: "controller/usecase/service unit tests"
      +fake ports only
    }

    lower_integration_tests: {
      shape: class
      label: "bootstrap / repository / XML wiring tests"
      +manual DI proof
      +concrete adapter proof
    }
  }

  bootstrap_package.composition_root -> controller_package.dictionary_controller: "manual DI で生成"
  bootstrap_package.composition_root -> usecase_package.master_dictionary_usecase: "manual DI で生成"
  bootstrap_package.composition_root -> service_package.query_service: "manual DI で生成"
  bootstrap_package.composition_root -> service_package.command_service: "manual DI で生成"
  bootstrap_package.composition_root -> service_package.import_service: "manual DI で生成"
  bootstrap_package.composition_root -> adapter_package.repository_adapter: "concrete adapter を生成"
  bootstrap_package.composition_root -> adapter_package.xml_file_adapter: "concrete adapter を生成"
  bootstrap_package.composition_root -> adapter_package.xml_record_reader_adapter: "concrete adapter を生成"
  bootstrap_package.composition_root -> adapter_package.runtime_event_adapter: "concrete adapter を生成"

  controller_package.dictionary_controller -> controller_package.usecase_port: "caller-owned port に依存"
  controller_package.usecase_port -> usecase_package.master_dictionary_usecase: "query / command / import を委譲"

  usecase_package.master_dictionary_usecase -> usecase_package.service_ports: "caller-owned port に依存"
  usecase_package.service_ports -> service_package.query_service: "query"
  usecase_package.service_ports -> service_package.command_service: "command"
  usecase_package.service_ports -> service_package.import_service: "import"
  usecase_package.service_ports -> adapter_package.runtime_event_adapter: "import 完了通知"

  service_package.query_service -> service_package.service_ports_owned: "caller-owned port に依存"
  service_package.command_service -> service_package.service_ports_owned: "caller-owned port に依存"
  service_package.import_service -> service_package.service_ports_owned: "caller-owned port に依存"

  service_package.service_ports_owned -> adapter_package.repository_adapter: "repository access"
  service_package.service_ports_owned -> adapter_package.xml_file_adapter: "filesystem access"
  service_package.service_ports_owned -> adapter_package.xml_record_reader_adapter: "XML decoding"
  service_package.service_ports_owned -> adapter_package.runtime_event_adapter: "runtime context / progress"

  testing_boundary.upper_unit_tests -> controller_package.dictionary_controller: "fake port で unit test" {
    style.stroke-dash: 4
  }
  testing_boundary.upper_unit_tests -> usecase_package.master_dictionary_usecase: "fake port で unit test" {
    style.stroke-dash: 4
  }
  testing_boundary.upper_unit_tests -> service_package.import_service: "fake port で unit test" {
    style.stroke-dash: 4
  }
  testing_boundary.lower_integration_tests -> bootstrap_package.composition_root: "manual DI wiring を検証" {
    style.stroke-dash: 4
  }
  testing_boundary.lower_integration_tests -> adapter_package.repository_adapter: "repository concrete を検証" {
    style.stroke-dash: 4
  }
  testing_boundary.lower_integration_tests -> adapter_package.xml_file_adapter: "filesystem / XML concrete を検証" {
    style.stroke-dash: 4
  }
}

style: {
  font-size: 20
}

edge: {
  style.font-size: 18
}
