direction: right

PLUGIN_EXPORT: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  target_plugin: string
  source_json_path: string
  imported_at: datetime
}

DIALOGUE_GROUP: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  player_text: string
  source: string
  quest_id: bigint {constraint: foreign_key}
  is_services_branch: boolean
  services_type: string
  nam1: string
}

DIALOGUE_RESPONSE: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  dialogue_group_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  response_order: integer
  source: string
  text: string
  prompt: string
  topic_text: string
  menu_display_text: string
  speaker_npc_id: bigint {constraint: foreign_key}
  speaker_form_id: string
  index: integer
  previous_response_id: bigint {constraint: foreign_key}
}

QUEST: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  source: string
  name: string
  type: string
}

QUEST_OBJECTIVE: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  quest_id: bigint {constraint: foreign_key}
  objective_index: string
  type: string
  parent_id: string
  parent_editor_id: string
  text: string
}

QUEST_STAGE_LOG: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  quest_id: bigint {constraint: foreign_key}
  stage_index: integer
  log_index: integer
  type: string
  parent_id: string
  parent_editor_id: string
  text: string
}

ITEM: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  source: string
  name: string
  description: string
  text: string
  type_hint: string
}

MAGIC: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  source: string
  name: string
  description: string
}

LOCATION: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  source: string
  name: string
  parent_id: string
}

SYSTEM_RECORD: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  source: string
  name: string
  description: string
}

MESSAGE: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  source: string
  text: string
  title: string
  quest_id: bigint {constraint: foreign_key}
}

LOAD_SCREEN: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  source: string
  text: string
}

NPC: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  plugin_export_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  type: string
  source: string
  name: string
  race: string
  voice: string
  sex: string
  class_name: string
}

DICTIONARY_ENTRY: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  source_text: string
  dest_text: string
}

PLUGIN_EXPORT.id -> DIALOGUE_GROUP.plugin_export_id
PLUGIN_EXPORT.id -> QUEST.plugin_export_id
PLUGIN_EXPORT.id -> ITEM.plugin_export_id
PLUGIN_EXPORT.id -> MAGIC.plugin_export_id
PLUGIN_EXPORT.id -> LOCATION.plugin_export_id
PLUGIN_EXPORT.id -> SYSTEM_RECORD.plugin_export_id
PLUGIN_EXPORT.id -> MESSAGE.plugin_export_id
PLUGIN_EXPORT.id -> LOAD_SCREEN.plugin_export_id
PLUGIN_EXPORT.id -> NPC.plugin_export_id
QUEST.id -> DIALOGUE_GROUP.quest_id
QUEST.id -> QUEST_OBJECTIVE.quest_id
QUEST.id -> QUEST_STAGE_LOG.quest_id
QUEST.id -> MESSAGE.quest_id
DIALOGUE_GROUP.id -> DIALOGUE_RESPONSE.dialogue_group_id
NPC.id -> DIALOGUE_RESPONSE.speaker_npc_id
DIALOGUE_RESPONSE.id -> DIALOGUE_RESPONSE.previous_response_id
