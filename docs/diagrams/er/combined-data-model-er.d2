direction: right

# Source of truth: docs/diagrams/conceptual/combined_perspective.puml
# This ER is intentionally one sheet. Deprecated split ER sources remain as pointers only.

X_EDIT_EXTRACTED_DATA: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  source_file_path: string
  source_tool: string
  target_plugin_name: string
  target_plugin_type: string
  record_count: integer
  imported_at: datetime
}

XTRANSLATOR_TRANSLATION_XML: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  file_path: string
  target_plugin_name: string
  target_plugin_type: string
  term_count: integer
  imported_at: datetime
}

TRANSLATION_RECORD: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  x_edit_extracted_data_id: bigint {constraint: foreign_key}
  form_id: string
  editor_id: string
  record_type: string
}

# Unique candidate: target_plugin_name + form_id + record_type
NPC_PROFILE: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  target_plugin_name: string
  form_id: string
  record_type: string
  editor_id: string
  display_name: string
  created_at: datetime
  updated_at: datetime
}

NPC_RECORD: {
  shape: sql_table
  translation_record_id: bigint {constraint: [primary_key, foreign_key]}
  npc_profile_id: bigint {constraint: foreign_key}
  race: string
  sex: string
  npc_class: string
  voice_type: string
}

TRANSLATION_FIELD_DEFINITION: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  record_type: string
  subrecord_type: string
  display_name: string
  ai_description: text
  translatable: boolean
  ordered: boolean
  order_scope: string
  reference_requirement: string
}

TRANSLATION_FIELD: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  translation_record_id: bigint {constraint: foreign_key}
  translation_field_definition_id: bigint {constraint: foreign_key}
  subrecord_type: string
  source_text: text
  field_order: integer
  previous_translation_field_id: bigint {constraint: foreign_key}
  next_translation_field_id: bigint {constraint: foreign_key}
}

TRANSLATION_FIELD_RECORD_REFERENCE: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  translation_field_id: bigint {constraint: foreign_key}
  referenced_translation_record_id: bigint {constraint: foreign_key}
  reference_role: string
}

# translation_job_id is set only for job_local lifecycle rows.
PERSONA: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  npc_profile_id: bigint {constraint: [foreign_key, unique]}
  translation_job_id: bigint {constraint: foreign_key}
  persona_lifecycle: string
  persona_scope: string
  persona_source: string
  persona_description: text
  speech_style: text
  personality_summary: text
  evidence_utterance_count: integer
  created_at: datetime
  updated_at: datetime
}

PERSONA_FIELD_EVIDENCE: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  persona_id: bigint {constraint: foreign_key}
  translation_field_id: bigint {constraint: foreign_key}
  evidence_role: string
}

# translation_job_id is set only for job_local lifecycle rows.
# xtranslator_translation_xml_id is import provenance, not ownership.
DICTIONARY_ENTRY: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  xtranslator_translation_xml_id: bigint {constraint: foreign_key}
  translation_job_id: bigint {constraint: foreign_key}
  dictionary_lifecycle: string
  dictionary_scope: string
  dictionary_source: string
  source_term: text
  translated_term: text
  term_kind: string
  reusable: boolean
  created_at: datetime
  updated_at: datetime
}

TRANSLATION_JOB: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  x_edit_extracted_data_id: bigint {constraint: foreign_key}
  job_name: string
  state: string
  progress_percent: integer
  created_at: datetime
  started_at: datetime
  finished_at: datetime
}

JOB_TRANSLATION_FIELD: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  translation_job_id: bigint {constraint: foreign_key}
  translation_field_id: bigint {constraint: foreign_key}
  applied_persona_id: bigint {constraint: foreign_key}
  translated_text: text
  output_status: string
  retry_count: integer
  updated_at: datetime
}

JOB_PHASE_RUN: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  translation_job_id: bigint {constraint: foreign_key}
  phase_type: string
  state: string
  execution_order: integer
  progress_percent: integer
  ai_provider: string
  model_name: string
  execution_mode: string
  credential_ref: string
  instruction_kind: string
  latest_external_run_id: string
  latest_error: text
  started_at: datetime
  finished_at: datetime
}

PHASE_RUN_TRANSLATION_FIELD: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  phase_run_id: bigint {constraint: foreign_key}
  job_translation_field_id: bigint {constraint: foreign_key}
  role: string
}

PHASE_RUN_PERSONA: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  phase_run_id: bigint {constraint: foreign_key}
  persona_id: bigint {constraint: foreign_key}
  role: string
}

PHASE_RUN_DICTIONARY_ENTRY: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  phase_run_id: bigint {constraint: foreign_key}
  dictionary_entry_id: bigint {constraint: foreign_key}
  role: string
}

TRANSLATION_ARTIFACT: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  translation_job_id: bigint {constraint: [foreign_key, unique]}
  artifact_format: string
  target_game: string
  file_path: string
  status: string
  generated_at: datetime
}

XTRANSLATOR_OUTPUT_ROW: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  translation_artifact_id: bigint {constraint: foreign_key}
  job_translation_field_id: bigint {constraint: [foreign_key, unique]}
  edid: string
  rec: string
  field: string
  formid: string
  source: text
  dest: text
  status: integer
}

# Input data and extracted records
X_EDIT_EXTRACTED_DATA.id -> TRANSLATION_RECORD.x_edit_extracted_data_id
TRANSLATION_RECORD.id -> NPC_RECORD.translation_record_id
NPC_PROFILE.id -> NPC_RECORD.npc_profile_id
TRANSLATION_RECORD.id -> TRANSLATION_FIELD.translation_record_id
TRANSLATION_FIELD_DEFINITION.id -> TRANSLATION_FIELD.translation_field_definition_id
TRANSLATION_FIELD.id -> TRANSLATION_FIELD.previous_translation_field_id
TRANSLATION_FIELD.id -> TRANSLATION_FIELD.next_translation_field_id
TRANSLATION_FIELD.id -> TRANSLATION_FIELD_RECORD_REFERENCE.translation_field_id
TRANSLATION_RECORD.id -> TRANSLATION_FIELD_RECORD_REFERENCE.referenced_translation_record_id

# Persona and dictionary shared / job-local generated data
NPC_PROFILE.id -> PERSONA.npc_profile_id
PERSONA.id -> PERSONA_FIELD_EVIDENCE.persona_id
TRANSLATION_FIELD.id -> PERSONA_FIELD_EVIDENCE.translation_field_id
XTRANSLATOR_TRANSLATION_XML.id -> DICTIONARY_ENTRY.xtranslator_translation_xml_id

# Job runtime
X_EDIT_EXTRACTED_DATA.id -> TRANSLATION_JOB.x_edit_extracted_data_id
TRANSLATION_JOB.id -> PERSONA.translation_job_id
TRANSLATION_JOB.id -> DICTIONARY_ENTRY.translation_job_id
TRANSLATION_JOB.id -> JOB_TRANSLATION_FIELD.translation_job_id
TRANSLATION_FIELD.id -> JOB_TRANSLATION_FIELD.translation_field_id
PERSONA.id -> JOB_TRANSLATION_FIELD.applied_persona_id
TRANSLATION_JOB.id -> JOB_PHASE_RUN.translation_job_id

# Phase effects and references
JOB_PHASE_RUN.id -> PHASE_RUN_TRANSLATION_FIELD.phase_run_id
JOB_TRANSLATION_FIELD.id -> PHASE_RUN_TRANSLATION_FIELD.job_translation_field_id
JOB_PHASE_RUN.id -> PHASE_RUN_PERSONA.phase_run_id
PERSONA.id -> PHASE_RUN_PERSONA.persona_id
JOB_PHASE_RUN.id -> PHASE_RUN_DICTIONARY_ENTRY.phase_run_id
DICTIONARY_ENTRY.id -> PHASE_RUN_DICTIONARY_ENTRY.dictionary_entry_id

# Output reconstruction
TRANSLATION_JOB.id -> TRANSLATION_ARTIFACT.translation_job_id
TRANSLATION_ARTIFACT.id -> XTRANSLATOR_OUTPUT_ROW.translation_artifact_id
JOB_TRANSLATION_FIELD.id -> XTRANSLATOR_OUTPUT_ROW.job_translation_field_id
