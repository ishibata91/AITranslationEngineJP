direction: right

MASTER_PERSONA: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  persona_name: string
  source_type: string
  built_at: datetime
}

MASTER_PERSONA_ENTRY: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  master_persona_id: bigint {constraint: foreign_key}
  npc_form_id: string
  npc_name: string
  race: string
  sex: string
  voice: string
  persona_text: string
}

FOUNDATION_PHASE_RUN: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  master_persona_id: bigint {constraint: foreign_key}
  phase_code: string
  ai_run_id: bigint {constraint: foreign_key}
  status: string
  started_at: datetime
  finished_at: datetime
}

MASTER_DICTIONARY: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  dictionary_name: string
  source_type: string
  built_at: datetime
}

MASTER_DICTIONARY_ENTRY: {
  shape: sql_table
  id: bigint {constraint: primary_key}
  master_dictionary_id: bigint {constraint: foreign_key}
  source_text: string
  dest_text: string
}

MASTER_PERSONA.id -> MASTER_PERSONA_ENTRY.master_persona_id
MASTER_PERSONA.id -> FOUNDATION_PHASE_RUN.master_persona_id
MASTER_DICTIONARY.id -> MASTER_DICTIONARY_ENTRY.master_dictionary_id
