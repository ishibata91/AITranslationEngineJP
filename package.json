{
  "name": "ai-translation-engine-jp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --require ./scripts/node/disable-vite-windows-net-use.cjs ./node_modules/vite/bin/vite.js --config ./vite.config.mjs --configLoader native",
    "build": "tsc --noEmit && node --require ./scripts/node/disable-vite-windows-net-use.cjs ./node_modules/vite/bin/vite.js build --config ./vite.config.mjs --configLoader native",
    "preview": "node --require ./scripts/node/disable-vite-windows-net-use.cjs ./node_modules/vite/bin/vite.js preview --config ./vite.config.mjs --configLoader native",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm run lint:oxlint && npm run lint:eslint && npm run lint:knip",
    "lint:backend": "npm run lint:rust",
    "lint:rust": "npm run lint:rust:fmt && npm run lint:rust:clippy",
    "lint:rust:fmt": "CARGO_HOME=.cargo-home cargo fmt --manifest-path ./src-tauri/Cargo.toml --all --check",
    "lint:rust:clippy": "CARGO_HOME=.cargo-home cargo clippy --manifest-path ./src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "lint:oxlint": "node ./scripts/lint/run-oxlint.mjs",
    "lint:eslint": "eslint src",
    "lint:knip": "knip --config knip.config.mjs",
    "scan:sonar": "node ./scripts/node/run-sonar-scanner.mjs",
    "test": "node --require ./scripts/node/disable-vite-windows-net-use.cjs ./node_modules/vitest/vitest.mjs run --pool threads --config ./vite.config.mjs --configLoader native",
    "test:rust": "CARGO_HOME=.cargo-home cargo test --manifest-path ./src-tauri/Cargo.toml --all-features",
    "gate:execution": "npm run format:check && npm run lint && npm run scan:sonar && npm run test && npm run test:rust && npm run build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "knip": "^5.0.0",
    "oxlint": "^1.0.0",
    "prettier": "^3.8.1",
    "svelte-eslint-parser": "^0.43.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
