{
  "name": "ai-translation-engine-jp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "npm run lint:oxlint && npm run lint:eslint && npm run lint:knip",
    "lint:oxlint": "oxlint src --deny-warnings",
    "lint:eslint": "eslint .",
    "lint:knip": "knip --config knip.json",
    "report:semgrep": "semgrep scan --config semgrep/semgrep.yml --error=false",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "knip": "^5.0.0",
    "oxlint": "^1.0.0",
    "svelte-eslint-parser": "^0.43.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
