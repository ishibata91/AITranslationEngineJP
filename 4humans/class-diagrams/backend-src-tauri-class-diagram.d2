direction: right

title: "Backend `src-tauri/src/` class overview"

gatewayLayer: {
  shape: package
  label: "gateway"

  commands: {
    shape: class
    label: "Tauri command 群 (`gateway/commands.rs`)"
  }
}

applicationLayer: {
  shape: package
  label: "application"

  bootstrapUsecase: {
    shape: class
    label: "起動状態取得ユースケース\n`GetBootstrapStatusUseCase`"
  }

  importUsecase: {
    shape: class
    label: "xEdit 取込ユースケース\n`ImportXeditExportUseCase`"
  }

  createJobUsecase: {
    shape: class
    label: "ジョブ作成ユースケース\n`CreateJobUseCase`"
  }

  listJobsUsecase: {
    shape: class
    label: "ジョブ一覧ユースケース\n`ListJobsUseCase`"
  }

  dtoLayer: {
    shape: class
    label: "DTO 群 (`application/dto`)"
  }
}

domainLayer: {
  shape: package
  label: "domain"

  bootstrapStatus: {
    shape: class
    label: "起動状態 (`BootstrapStatus`)"
  }

  jobDomain: {
    shape: class
    label: "job domain\n`CreatedJob` / `ListedJob` / `JobState` / `create_ready_job`"
  }

  importDomain: {
    shape: class
    label: "import domain\n`ImportedPluginExport` / `ImportedRawRecord` / `TranslationUnit`"
  }
}

infraLayer: {
  shape: package
  label: "infra"

  runtimeInfo: {
    shape: class
    label: "runtime provider (`CargoRuntimeInfoProvider`)"
  }

  fileImporter: {
    shape: class
    label: "filesystem importer (`FileSystemXeditExportImporter`)"
  }

  sqliteRepo: {
    shape: class
    label: "SQLite export repository (`SqlitePluginExportRepository`)"
  }

  inMemoryRepo: {
    shape: class
    label: "memory job repository (`InMemoryJobRepository`)"
  }
}

gatewayLayer.commands -> applicationLayer.bootstrapUsecase: 起動状態取得を呼ぶ
gatewayLayer.commands -> applicationLayer.importUsecase: 取込を呼ぶ
gatewayLayer.commands -> applicationLayer.createJobUsecase: ジョブ作成を呼ぶ
gatewayLayer.commands -> applicationLayer.listJobsUsecase: ジョブ一覧を呼ぶ
applicationLayer.bootstrapUsecase -> domainLayer.bootstrapStatus: domain を組み立てる
applicationLayer.bootstrapUsecase -> infraLayer.runtimeInfo: 版情報を使う
applicationLayer.bootstrapUsecase -> applicationLayer.dtoLayer: DTO へ写す
applicationLayer.importUsecase -> domainLayer.importDomain: import domain を作る
applicationLayer.importUsecase -> infraLayer.fileImporter: file を読む
applicationLayer.importUsecase -> infraLayer.sqliteRepo: 保存する
applicationLayer.importUsecase -> applicationLayer.dtoLayer: DTO へ写す
applicationLayer.createJobUsecase -> domainLayer.jobDomain: job domain を作る
applicationLayer.createJobUsecase -> infraLayer.inMemoryRepo: 保存する
applicationLayer.createJobUsecase -> applicationLayer.dtoLayer: DTO へ写す
applicationLayer.listJobsUsecase -> domainLayer.jobDomain: job domain を参照する
applicationLayer.listJobsUsecase -> infraLayer.inMemoryRepo: 一覧を読む
applicationLayer.listJobsUsecase -> applicationLayer.dtoLayer: DTO へ写す
