direction: right

title: "Backend create-job class diagram"

gateway: {
  shape: package
  label: "gateway"

  command: {
    shape: class
    label: "ジョブ作成 command (`create_job(request)`)"
  }
}

application: {
  shape: package
  label: "application"

  usecase: {
    shape: class
    label: "ジョブ作成ユースケース (`CreateJobUseCase`)\n+ 作成要求を実行する (`execute(request)`)"
  }

  requestDto: {
    shape: class
    label: "ジョブ作成要求 DTO (`CreateJobRequestDto`)"
  }

  resultDto: {
    shape: class
    label: "ジョブ作成結果 DTO (`CreateJobResultDto`)"
  }

  repoPort: {
    shape: class
    label: "repository port (`CreateJobRepository`)\n+ 作成済みジョブを保存する (`save_created_job(created_job)`)"
  }
}

domain: {
  shape: package
  label: "domain"

  translationUnit: {
    shape: class
    label: "翻訳単位 (`TranslationUnit`)"
  }

  sourceGroup: {
    shape: class
    label: "ジョブ作成入力群 (`CreateJobSourceGroup`)"
  }

  createReadyJob: {
    shape: class
    label: "準備完了ジョブ生成 (`create_ready_job(job_id, source_groups)`)"
  }

  createdJob: {
    shape: class
    label: "作成済みジョブ (`CreatedJob`)"
  }
}

infra: {
  shape: package
  label: "infra"

  repoImpl: {
    shape: class
    label: "memory job repository (`InMemoryJobRepository`)"
  }
}

gateway.command -> application.usecase: 作成要求を渡す
application.usecase -> application.requestDto: request を受け取る
application.usecase -> domain.translationUnit: DTO を変換する
application.usecase -> domain.sourceGroup: source group を組み立てる
application.usecase -> domain.createReadyJob: 準備完了ジョブを作る
application.usecase -> application.repoPort: 作成済みジョブを保存する
infra.repoImpl -> application.repoPort: 実装する
domain.createReadyJob -> domain.createdJob: 作成済みジョブを返す
application.usecase -> application.resultDto: 結果 DTO を返す
