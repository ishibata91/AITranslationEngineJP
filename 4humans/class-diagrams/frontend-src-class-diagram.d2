direction: right

title: "Frontend `src/` class overview"

app: {
  shape: package
  label: "アプリ起動"

  mainTs: {
    shape: class
    label: "フロント起動点 (`main.ts`)"
  }

  appSvelte: {
    shape: class
    label: "アプリ受け口 (`App.svelte`)"
  }

  appShell: {
    shape: class
    label: "画面シェル (`AppShell.svelte`)"
  }
}

slices: {
  shape: package
  label: "画面 slice"

  jobListSlice: {
    shape: class
    label: "ジョブ一覧 slice\n`JobListScreen` / `JobListView` / `JobListScreenInput` / `JobListScreenStore`"
  }

  jobCreateSlice: {
    shape: class
    label: "ジョブ作成 slice\n`JobCreateScreen` / `JobCreateView` / `JobCreateScreenInput` / `JobCreateScreenStore`"
  }

  bootstrapSlice: {
    shape: class
    label: "起動状態 slice\n`BootstrapStatusScreen` / `BootstrapStatusScreenInput` / `BootstrapStatusScreenStore`"
  }
}

gatewayLayer: {
  shape: package
  label: "gateway"

  jobListGateway: {
    shape: class
    label: "ジョブ一覧 gateway (`createTauriJobListExecutor()`)"
  }

  jobCreateGateway: {
    shape: class
    label: "ジョブ作成 gateway (`createTauriJobCreateExecutor()`)"
  }

  bootstrapGateway: {
    shape: class
    label: "起動状態 gateway (`createTauriBootstrapStatusGateway()`)"
  }
}

contracts: {
  shape: package
  label: "shared contract"

  bootstrapStatus: {
    shape: class
    label: "起動状態 contract (`BootstrapStatus`)"
  }

  jobListResult: {
    shape: class
    label: "ジョブ一覧結果 (`JobListResult`)"
  }

  jobCreatePair: {
    shape: class
    label: "ジョブ作成 request/result\n`JobCreateRequest` / `JobCreateResult`"
  }
}

app.mainTs -> app.appSvelte: mount する
app.appSvelte -> app.appShell: 画面 props を渡す
app.mainTs -> slices.jobListSlice: 組み立てる
app.mainTs -> slices.jobCreateSlice: 組み立てる
app.mainTs -> slices.bootstrapSlice: 組み立てる
app.appShell -> slices.jobListSlice: 表示する
app.appShell -> slices.jobCreateSlice: 表示する
app.appShell -> slices.bootstrapSlice: 表示する
slices.jobListSlice -> gatewayLayer.jobListGateway: 一覧取得を依頼する
slices.jobCreateSlice -> gatewayLayer.jobCreateGateway: 作成を依頼する
slices.bootstrapSlice -> gatewayLayer.bootstrapGateway: 起動状態取得を依頼する
gatewayLayer.jobListGateway -> contracts.jobListResult: 一覧結果を返す
gatewayLayer.jobCreateGateway -> contracts.jobCreatePair: request/result を扱う
gatewayLayer.bootstrapGateway -> contracts.bootstrapStatus: 起動状態を返す
