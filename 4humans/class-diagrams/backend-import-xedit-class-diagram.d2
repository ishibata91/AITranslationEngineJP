direction: right

title: "Backend import-xedit class diagram"

gateway: {
  shape: package
  label: "gateway"

  command: {
    shape: class
    label: "xEdit 取込 command (`import_xedit_export_json(request)`)"
  }
}

application: {
  shape: package
  label: "application"

  usecase: {
    shape: class
    label: "xEdit 取込ユースケース (`ImportXeditExportUseCase`)\n+ 取込要求を実行する (`execute(request)`)"
  }

  requestDto: {
    shape: class
    label: "xEdit 取込要求 DTO (`ImportXeditExportRequestDto`)"
  }

  resultDto: {
    shape: class
    label: "xEdit 取込結果 DTO (`ImportXeditExportResultDto`)"
  }

  importerPort: {
    shape: class
    label: "importer port (`XeditExportImporter`)\n+ ファイル群を取り込む (`import_from_paths(file_paths)`)"
  }

  repoPort: {
    shape: class
    label: "repository port (`ImportedPluginExportRepository`)\n+ 取込済み export 群を保存する (`save_imported_plugin_exports(plugin_exports)`)"
  }
}

domain: {
  shape: package
  label: "domain"

  pluginExport: {
    shape: class
    label: "取込済み export (`ImportedPluginExport`)"
  }

  rawRecord: {
    shape: class
    label: "取込済み生レコード (`ImportedRawRecord`)"
  }

  translationUnit: {
    shape: class
    label: "翻訳単位 (`TranslationUnit`)"
  }
}

infra: {
  shape: package
  label: "infra"

  importerImpl: {
    shape: class
    label: "filesystem importer (`FileSystemXeditExportImporter`)"
  }

  repoImpl: {
    shape: class
    label: "SQLite export repository (`SqlitePluginExportRepository`)"
  }
}

gateway.command -> application.usecase: 取込要求を渡す
application.usecase -> application.requestDto: request を受け取る
application.usecase -> application.importerPort: file import を依頼する
infra.importerImpl -> application.importerPort: 実装する
infra.importerImpl -> domain.translationUnit: 翻訳単位を作る
infra.importerImpl -> domain.rawRecord: 生レコードを作る
infra.importerImpl -> domain.pluginExport: export を組み立てる
application.usecase -> application.repoPort: 取込済み export 群を保存する
infra.repoImpl -> application.repoPort: 実装する
application.usecase -> application.resultDto: 結果 DTO を返す
