title: "Frontend 起動状態画面シーケンス図"

bootstrapStatusSequence: {
  shape: sequence_diagram

  user: "利用者"
  bootstrapStatusScreen: "起動状態画面 (`BootstrapStatusScreen.svelte`)"
  bootstrapStatusUsecase: "起動状態ユースケース (`BootstrapStatusScreenInput`)"
  bootstrapStatusStore: "起動状態ストア (`BootstrapStatusScreenStore`)"
  bootstrapStatusGateway: "起動状態 gateway (`createTauriBootstrapStatusGateway()`)"
  featureScreenGateway: "汎用 Tauri gateway (`createTauriFeatureScreenGateway()`)"
  tauriBackend: "Tauri command (`get_bootstrap_status`)"
  bootstrapStatusView: "起動状態ビュー (`BootstrapStatusView.svelte`)"

  user -> bootstrapStatusScreen: 画面を開く {
    style.font-size: 22
  }
  bootstrapStatusScreen -> bootstrapStatusUsecase: 初期化する (`initialize()`) {
    style.font-size: 22
  }
  bootstrapStatusUsecase -> bootstrapStatusStore: 読込中にする (`setLoading()`) {
    style.font-size: 22
  }
  bootstrapStatusUsecase -> bootstrapStatusGateway: 状態取得を依頼する {
    style.font-size: 22
  }
  bootstrapStatusGateway -> featureScreenGateway: 汎用 `load()` を呼ぶ {
    style.font-size: 22
  }
  featureScreenGateway -> tauriBackend: 起動状態を取得する {
    style.font-size: 22
  }
  tauriBackend -> featureScreenGateway: 起動状態を返す {
    style.font-size: 22
  }
  featureScreenGateway -> bootstrapStatusGateway: 解決済み結果を返す {
    style.font-size: 22
  }
  bootstrapStatusGateway -> bootstrapStatusUsecase: 解決済み結果を返す {
    style.font-size: 22
  }
  bootstrapStatusUsecase -> bootstrapStatusStore: 読込済み状態を設定する {
    style.font-size: 22
  }
  bootstrapStatusStore -> bootstrapStatusView: 購読済み状態を反映する {
    style.font-size: 22
  }
  user -> bootstrapStatusView: 項目 (`BootstrapStatusField`) を選ぶ {
    style.font-size: 22
  }
  bootstrapStatusView -> bootstrapStatusUsecase: 選択する (`select(selection)`) {
    style.font-size: 22
  }
  bootstrapStatusUsecase -> bootstrapStatusStore: 選択状態を設定する {
    style.font-size: 22
  }
}
