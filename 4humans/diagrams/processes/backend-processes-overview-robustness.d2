layout: dagre
direction: down

title: "Backend 主要プロセス overview"

bootstrapStatus: {
  shape: package
  label: "起動状態取得"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "command 境界 (`get_bootstrap_status`)"
    link: "./backend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "取得制御 (`GetBootstrapStatusUseCase`)"
    link: "./backend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "起動状態 (`BootstrapStatus`)"
    link: "./backend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 状態取得 {
    style.font-size: 22
  }
  control -> entity: runtime 集約 {
    style.font-size: 22
  }
}

createJob: {
  shape: package
  label: "ジョブ作成"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "command 境界 (`create_job`)"
    link: "./backend-create-job-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "作成制御 (`CreateJobUseCase`)"
    link: "./backend-create-job-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "作成結果 (`CreateJobResultDto` / `job`)"
    link: "./backend-create-job-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 作成要求 {
    style.font-size: 22
  }
  control -> entity: job 保存 {
    style.font-size: 22
  }
}

listJobs: {
  shape: package
  label: "ジョブ一覧取得"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "command 境界 (`list_jobs`)"
    link: "./backend-list-jobs-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "一覧取得 (`ListJobsUseCase`)"
    link: "./backend-list-jobs-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "一覧結果 (`JobListResultDto`)"
    link: "./backend-list-jobs-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 一覧要求 {
    style.font-size: 22
  }
  control -> entity: job 一覧 {
    style.font-size: 22
  }
}

importXedit: {
  shape: package
  label: "xEdit 取込"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "command 境界 (`import_xedit_export_json`)"
    link: "./backend-import-xedit-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "取込制御 (`ImportXeditExportUseCase`)"
    link: "./backend-import-xedit-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "取込結果 (`ImportedPluginExport` / `TranslationUnit`)"
    link: "./backend-import-xedit-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 取込要求 {
    style.font-size: 22
  }
  control -> entity: 取込と保存 {
    style.font-size: 22
  }
}

dictionaryStorageQuery: {
  shape: package
  label: "辞書保存・検索"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "command 境界 (`rebuild_dictionary` / `lookup_dictionary`)"
    link: "./backend-dictionary-storage-query-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "保存・検索制御 (`SaveImportedDictionaryUseCase` / `LookupDictionaryUseCase`)"
    link: "./backend-dictionary-storage-query-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "辞書結果 (`DictionaryLookupResult`)"
    link: "./backend-dictionary-storage-query-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 再構築/検索 {
    style.font-size: 22
  }
  control -> entity: exact match 観測 {
    style.font-size: 22
  }
}

masterPersonaRebuild: {
  shape: package
  label: "master persona 再構築"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "command 境界 (`rebuild_master_persona` / `read_master_persona`)"
    link: "./backend-master-persona-builder-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "再構築制御 (`RebuildMasterPersonaUseCase`)"
    link: "./backend-master-persona-builder-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "結果 (`MasterPersonaReadResultDto`)"
    link: "./backend-master-persona-builder-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: save/read {
    style.font-size: 22
  }
  control -> entity: build と観測 {
    style.font-size: 22
  }
}

jobPersonaPersistence: {
  shape: package
  label: "job persona 永続化"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "保存要求境界 (`JobPersonaSaveRequestDto`)"
    link: "./backend-job-persona-persistence-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "永続化制御 (`PersistJobPersonaUseCase`)"
    link: "./backend-job-persona-persistence-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "snapshot (`JobPersonaReadResultDto`)"
    link: "./backend-job-persona-persistence-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: save/read {
    style.font-size: 22
  }
  control -> entity: 保存順読込 {
    style.font-size: 22
  }
}

translationFlowMvp: {
  shape: package
  label: "translation flow MVP proof"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "gateway helper (`run_translation_flow_mvp_orchestration`)"
    link: "./backend-translation-flow-mvp-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "phase 制御 (`RunWord...` / `RunNpc...` / `RunBody...`)"
    link: "./backend-translation-flow-mvp-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "proof 結果 (`TranslationPreviewItemDto`)"
    link: "./backend-translation-flow-mvp-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: orchestration {
    style.font-size: 22
  }
  control -> entity: preview 生成 {
    style.font-size: 22
  }
}

bootstrapStatus -> createJob: 次の主題 {
  style.font-size: 22
}
createJob -> listJobs: 次の主題 {
  style.font-size: 22
}
listJobs -> importXedit: 次の主題 {
  style.font-size: 22
}
importXedit -> dictionaryStorageQuery: 次の主題 {
  style.font-size: 22
}
dictionaryStorageQuery -> masterPersonaRebuild: 次の主題 {
  style.font-size: 22
}
masterPersonaRebuild -> jobPersonaPersistence: 次の主題 {
  style.font-size: 22
}
jobPersonaPersistence -> translationFlowMvp: 次の主題 {
  style.font-size: 22
}
