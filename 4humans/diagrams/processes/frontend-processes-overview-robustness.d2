layout: dagre
direction: down

title: "Frontend 主要プロセス overview"

bootstrapStatus: {
  shape: package
  label: "起動状態確認"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "画面境界 (`BootstrapStatusScreen` / `BootstrapStatusView`)"
    link: "./frontend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "画面制御 (`BootstrapStatusScreenInput`)"
    link: "./frontend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "起動状態 (`BootstrapStatus`)"
    link: "./frontend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 初期化と再読込 {
    style.font-size: 22
  }
  control -> entity: 状態取得 {
    style.font-size: 22
  }
}

jobList: {
  shape: package
  label: "ジョブ一覧確認"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "画面境界 (`JobListScreen` / `JobListView`)"
    link: "./frontend-job-list-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "画面制御 (`JobListScreenInput`)"
    link: "./frontend-job-list-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "一覧結果 (`JobListResult`)"
    link: "./frontend-job-list-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 初期化と選択 {
    style.font-size: 22
  }
  control -> entity: 一覧取得 {
    style.font-size: 22
  }
}

jobCreate: {
  shape: package
  label: "ジョブ作成"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "画面境界 (`JobCreateScreen` / `JobCreateView`)"
    link: "./frontend-job-create-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "画面制御 (`JobCreateScreenInput`)"
    link: "./frontend-job-create-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "作成結果 (`JobCreateResult`)"
    link: "./frontend-job-create-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 入力と送信 {
    style.font-size: 22
  }
  control -> entity: 作成実行 {
    style.font-size: 22
  }
}

dictionaryObserve: {
  shape: package
  label: "辞書観測"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "画面・Tauri 境界 (`DictionaryObserveView` / executor)"
    link: "./frontend-dictionary-observe-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "画面制御 (`DictionaryObserveScreenInput`)"
    link: "./frontend-dictionary-observe-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "観測結果 (`DictionaryObserveResult`)"
    link: "./frontend-dictionary-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 入力と観測 {
    style.font-size: 22
  }
  control -> entity: exact match 候補取得 {
    style.font-size: 22
  }
}

personaObserve: {
  shape: package
  label: "ペルソナ観測"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "画面・Tauri 境界 (`PersonaObserveView` / executor)"
    link: "./frontend-persona-observe-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "画面制御 (`PersonaObserveScreenInput`)"
    link: "./frontend-persona-observe-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "観測結果 (`PersonaObserveResult`)"
    link: "./frontend-persona-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 入力と観測 {
    style.font-size: 22
  }
  control -> entity: master persona 取得 {
    style.font-size: 22
  }
}

executionObserve: {
  shape: package
  label: "実行観測"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "画面・Tauri 境界 (`ExecutionObserveView` / loader)"
    link: "./frontend-execution-observe-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "画面制御 (`ExecutionObserveScreenInput`)"
    link: "./frontend-execution-observe-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "観測 snapshot (`ExecutionObserveSnapshot`)"
    link: "./frontend-execution-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: 初期化と refresh {
    style.font-size: 22
  }
  control -> entity: progress / failure 取得 {
    style.font-size: 22
  }
}

executionControl: {
  shape: package
  label: "実行制御"
  direction: down
  style.font-size: 22

  boundary: {
    shape: class
    label: "画面境界 (`ExecutionControlView`)"
    link: "./frontend-execution-control-sequence-diagram.svg"
    style.font-size: 22
  }
  control: {
    shape: class
    label: "画面制御 (`ExecutionControlScreenInput`)"
    link: "./frontend-execution-control-sequence-diagram.svg"
    style.font-size: 22
  }
  entity: {
    shape: class
    label: "確定 snapshot (`ExecutionControlSnapshot`)"
    link: "./frontend-execution-control-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary -> control: control action {
    style.font-size: 22
  }
  control -> entity: stable state 読取 {
    style.font-size: 22
  }
}

bootstrapStatus -> jobList: 次の主題 {
  style.font-size: 22
}
jobList -> jobCreate: 次の主題 {
  style.font-size: 22
}
jobCreate -> dictionaryObserve: 次の主題 {
  style.font-size: 22
}
dictionaryObserve -> personaObserve: 次の主題 {
  style.font-size: 22
}
personaObserve -> executionObserve: 次の主題 {
  style.font-size: 22
}
executionObserve -> executionControl: 次の主題 {
  style.font-size: 22
}
