layout: elk
direction: down

title: "主要プロセス overview robustness 図"

bootstrapStatus: {
  shape: package
  label: "起動状態確認"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "利用者"
    link: "./frontend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "画面境界 (`BootstrapStatusScreen` / `BootstrapStatusView`)"
    link: "./frontend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "画面制御 (`BootstrapStatusScreenInput` / `createBootstrapStatusScreenUsecase()`)"
    link: "./frontend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "起動状態 (`BootstrapStatus`)"
    link: "./frontend-bootstrap-status-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: 画面を開く {
    style.font-size: 22
  }
  boundary -> control: 初期化と再読込を依頼する {
    style.font-size: 22
  }
  control -> entity: 起動状態を取得する {
    style.font-size: 22
  }
}

jobList: {
  shape: package
  label: "ジョブ一覧確認"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "利用者"
    link: "./frontend-job-list-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "画面境界 (`JobListScreen` / `JobListView`)"
    link: "./frontend-job-list-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "画面制御 (`JobListScreenInput` / `createJobListScreenUsecase()`)"
    link: "./frontend-job-list-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "一覧結果 (`JobListResult`)"
    link: "./frontend-job-list-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: 画面を開いて選択する {
    style.font-size: 22
  }
  boundary -> control: 初期化と操作を渡す {
    style.font-size: 22
  }
  control -> entity: 一覧を取得する {
    style.font-size: 22
  }
}

jobCreate: {
  shape: package
  label: "ジョブ作成"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "利用者"
    link: "./frontend-job-create-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "画面境界 (`JobCreateScreen` / `JobCreateView`)"
    link: "./frontend-job-create-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "画面制御 (`JobCreateScreenInput` / `createJobCreateScreenUsecase()`)"
    link: "./frontend-job-create-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "作成結果 (`JobCreateResult`)"
    link: "./frontend-job-create-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: 入力して送信する {
    style.font-size: 22
  }
  boundary -> control: 送信と更新を渡す {
    style.font-size: 22
  }
  control -> entity: ジョブを作成する {
    style.font-size: 22
  }
}

dictionaryObserve: {
  shape: package
  label: "辞書観測"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "利用者"
    link: "./frontend-dictionary-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "画面境界 (`DictionaryObserveScreen` / `DictionaryObserveView`)"
    link: "./frontend-dictionary-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "画面制御 (`DictionaryObserveScreenInput` / `createDictionaryObserveScreenUsecase()`)"
    link: "./frontend-dictionary-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "観測結果 (`DictionaryObserveResult`)"
    link: "./frontend-dictionary-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: 語句を入力して観測する {
    style.font-size: 22
  }
  boundary -> control: 入力と操作を渡す {
    style.font-size: 22
  }
  control -> entity: exact match 候補を取得する {
    style.font-size: 22
  }
}

personaObserve: {
  shape: package
  label: "ペルソナ観測"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "利用者"
    link: "./frontend-persona-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "画面境界 (`PersonaObserveScreen` / `PersonaObserveView`)"
    link: "./frontend-persona-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "画面制御 (`PersonaObserveScreenInput` / `createPersonaObserveScreenUsecase()`)"
    link: "./frontend-persona-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "観測結果 (`PersonaObserveResult`)"
    link: "./frontend-persona-observe-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: ペルソナ名を入力して観測する {
    style.font-size: 22
  }
  boundary -> control: 入力と操作を渡す {
    style.font-size: 22
  }
  control -> entity: master persona を取得する {
    style.font-size: 22
  }
}

importXedit: {
  shape: package
  label: "xEdit 取込"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "呼出し元"
    link: "./backend-import-xedit-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "command 境界 (`import_xedit_export_json`)"
    link: "./backend-import-xedit-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "取込制御 (`ImportXeditExportUseCase`)"
    link: "./backend-import-xedit-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "取込結果 (`ImportedPluginExport` / `TranslationUnit`)"
    link: "./backend-import-xedit-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: 取込要求を渡す {
    style.font-size: 22
  }
  boundary -> control: 取込処理を呼ぶ {
    style.font-size: 22
  }
  control -> entity: 取込と保存を行う {
    style.font-size: 22
  }
}

dictionaryStorageQuery: {
  shape: package
  label: "辞書保存・検索"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "呼出し元"
    link: "./backend-dictionary-storage-query-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "検索 port 境界 (`DictionaryLookupPort`)"
    link: "./backend-dictionary-storage-query-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "保存・検索制御 (`SaveImportedDictionaryUseCase` / `LookupDictionaryUseCase`)"
    link: "./backend-dictionary-storage-query-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "辞書結果 (`DictionaryImportResultDto` / `DictionaryLookupResult`)"
    link: "./backend-dictionary-storage-query-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: 保存後に検索要求を渡す {
    style.font-size: 22
  }
  boundary -> control: 保存と検索を依頼する {
    style.font-size: 22
  }
  control -> entity: 永続化と exact match を行う {
    style.font-size: 22
  }
}

masterPersonaRebuild: {
  shape: package
  label: "master persona 再構築"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "呼出し元"
    link: "./backend-master-persona-builder-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "base-game NPC 入力境界 (`BaseGameNpcRebuildRequest`)"
    link: "./backend-master-persona-builder-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "再構築制御 (`RebuildMasterPersonaUseCase` / `BaseGameNpcMasterPersonaBuilder`)"
    link: "./backend-master-persona-builder-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "再構築結果 (`MasterPersonaSaveRequestDto` / `MasterPersonaReadResultDto`)"
    link: "./backend-master-persona-builder-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: base-game NPC 入力を渡す {
    style.font-size: 22
  }
  boundary -> control: 再構築を呼ぶ {
    style.font-size: 22
  }
  control -> entity: build と save/read を行う {
    style.font-size: 22
  }
}

jobPersonaPersistence: {
  shape: package
  label: "job persona 永続化"
  direction: right
  style.font-size: 22

  actor: {
    shape: person
    label: "呼出し元"
    link: "./backend-job-persona-persistence-sequence-diagram.svg"
    style.font-size: 22
  }

  boundary: {
    shape: class
    label: "job persona 保存要求境界 (`JobPersonaSaveRequestDto`)"
    link: "./backend-job-persona-persistence-sequence-diagram.svg"
    style.font-size: 22
  }

  control: {
    shape: class
    label: "永続化制御 (`PersistJobPersonaUseCase` / `SqliteJobPersonaRepository`)"
    link: "./backend-job-persona-persistence-sequence-diagram.svg"
    style.font-size: 22
  }

  entity: {
    shape: class
    label: "job-local snapshot (`JobPersonaReadResultDto` / `JOB_PERSONA_ENTRY`)"
    link: "./backend-job-persona-persistence-sequence-diagram.svg"
    style.font-size: 22
  }

  actor -> boundary: job persona 保存要求を渡す {
    style.font-size: 22
  }
  boundary -> control: save/read を直列実行させる {
    style.font-size: 22
  }
  control -> entity: 置換保存と保存順読込を行う {
    style.font-size: 22
  }
}
