title: "Backend 起動状態取得シーケンス図"

bootstrapStatusSequence: {
  shape: sequence_diagram

  frontend: "フロント呼出し (`invoke`)"
  commands: "起動状態 command 境界 (`gateway::commands::get_bootstrap_status`)"
  usecase: "起動状態ユースケース (`GetBootstrapStatusUseCase`)"
  runtimeInfo: "runtime 情報提供 (`CargoRuntimeInfoProvider`)"
  domain: "起動状態 (`BootstrapStatus`)"
  dto: "起動状態 DTO (`BootstrapStatusDto`)"

  frontend -> commands: command を呼ぶ {
    style.font-size: 22
  }
  commands -> usecase: 実行する (`execute()`) {
    style.font-size: 22
  }
  usecase -> runtimeInfo: backend 版を取得する {
    style.font-size: 22
  }
  runtimeInfo -> usecase: 版情報を返す {
    style.font-size: 22
  }
  usecase -> domain: 起動状態を組み立てる {
    style.font-size: 22
  }
  domain -> usecase: 状態を返す {
    style.font-size: 22
  }
  usecase -> dto: DTO を作る {
    style.font-size: 22
  }
  dto -> commands: 起動状態 DTO を返す {
    style.font-size: 22
  }
  commands -> frontend: 結果を返す {
    style.font-size: 22
  }
}
