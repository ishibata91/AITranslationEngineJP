title: "Backend master persona 再構築シーケンス図"

masterPersonaRebuildSequence: {
  shape: sequence_diagram

  frontend: "Tauri executor (`createTauriPersonaObserveExecutor`)"
  rebuildCommand: "master persona 再構築 command (`gateway::commands::rebuild_master_persona`)"
  runtimeOrchestrator: "master persona runtime orchestrator (`RunMasterPersonaGenerationRuntimeUseCase`)"
  providerRuntime: "provider runtime port (`ProviderRuntimePort`)"
  readCommand: "master persona 観測 command (`gateway::commands::read_master_persona`)"
  rebuildUsecase: "master persona 再構築ユースケース (`RebuildMasterPersonaUseCase`)"
  builder: "base-game NPC master persona builder (`BaseGameNpcMasterPersonaBuilder`)"
  storagePort: "master persona repository (`SqliteMasterPersonaRepository`)"
  readResult: "master persona 読込結果 DTO (`MasterPersonaReadResultDto`)"

  frontend -> rebuildCommand: runtime 要求 + base-game NPC 入力を渡す {
    style.font-size: 22
  }
  rebuildCommand -> runtimeOrchestrator: provider-backed 再構築を実行する (`execute(request)`) {
    style.font-size: 22
  }
  runtimeOrchestrator -> runtimeOrchestrator: `source=MasterPersonaSeed` と `sink=PersonaStorage` を guard する {
    style.font-size: 22
  }
  runtimeOrchestrator -> rebuildCommand: 非対応 route は module で拒否する {
    style.font-size: 22
    style.stroke-dash: 5
  }
  runtimeOrchestrator -> providerRuntime: provider runtime を先に実行する {
    style.font-size: 22
  }
  providerRuntime -> runtimeOrchestrator: provider 成功または failure を返す {
    style.font-size: 22
  }
  runtimeOrchestrator -> rebuildUsecase: provider 成功後だけ再構築へ進む {
    style.font-size: 22
  }
  rebuildUsecase -> builder: 保存要求を構築する {
    style.font-size: 22
  }
  builder -> builder: `source_type` と必須 field を検証する {
    style.font-size: 22
  }
  builder -> builder: entry 順序を保って保存要求を組み立てる {
    style.font-size: 22
  }
  builder -> rebuildUsecase: 保存要求を返す {
    style.font-size: 22
  }
  rebuildUsecase -> rebuildUsecase: `persona_name` から読込要求を組み立てる {
    style.font-size: 22
  }
  rebuildUsecase -> storagePort: master persona を保存する {
    style.font-size: 22
  }
  storagePort -> rebuildUsecase: 保存結果を返す {
    style.font-size: 22
  }
  rebuildUsecase -> storagePort: 保存後の master persona を読む {
    style.font-size: 22
  }
  storagePort -> readResult: 保存済み master persona を返す {
    style.font-size: 22
  }
  readResult -> rebuildUsecase: 読込結果を返す {
    style.font-size: 22
  }
  rebuildUsecase -> runtimeOrchestrator: 再構築結果を返す {
    style.font-size: 22
  }
  runtimeOrchestrator -> rebuildCommand: 再構築結果を返す {
    style.font-size: 22
  }
  rebuildCommand -> frontend: 保存後の `entries` を返す {
    style.font-size: 22
  }
  frontend -> readCommand: 観測要求 (`MasterPersonaReadRequestDto`) を渡す {
    style.font-size: 22
  }
  readCommand -> storagePort: 読込だけを実行する {
    style.font-size: 22
  }
  storagePort -> readResult: 保存済み master persona を返す {
    style.font-size: 22
  }
  readResult -> readCommand: 読込結果を返す {
    style.font-size: 22
  }
  readCommand -> frontend: 観測結果を返す {
    style.font-size: 22
  }
}
