title: "Frontend 辞書観測画面シーケンス図"

dictionaryObserveSequence: {
  shape: sequence_diagram

  user: "利用者"
  dictionaryObserveScreen: "辞書観測画面 (`DictionaryObserveScreen.svelte`)"
  dictionaryObserveUsecase: "辞書観測ユースケース (`DictionaryObserveScreenInput`)"
  dictionaryObserveStore: "辞書観測ストア (`DictionaryObserveScreenStore`)"
  observeExecutor: "観測 executor (`executor`)"
  dictionaryObserveView: "辞書観測ビュー (`DictionaryObserveView.svelte`)"

  user -> dictionaryObserveScreen: 画面を開く {
    style.font-size: 22
  }
  dictionaryObserveScreen -> dictionaryObserveUsecase: 初期化する (`initialize()`) {
    style.font-size: 22
  }
  dictionaryObserveUsecase -> dictionaryObserveStore: 初期状態を維持する {
    style.font-size: 22
  }
  dictionaryObserveStore -> dictionaryObserveView: empty state を反映する {
    style.font-size: 22
  }
  user -> dictionaryObserveView: `sourceTexts` を入力する {
    style.font-size: 22
  }
  dictionaryObserveView -> dictionaryObserveUsecase: 入力を更新する (`updateFilters()`) {
    style.font-size: 22
  }
  dictionaryObserveUsecase -> dictionaryObserveStore: 現在入力を保存する {
    style.font-size: 22
  }
  user -> dictionaryObserveView: 観測を実行する {
    style.font-size: 22
  }
  dictionaryObserveView -> dictionaryObserveUsecase: 観測する (`observe()`) {
    style.font-size: 22
  }
  dictionaryObserveUsecase -> dictionaryObserveStore: 読込中にする {
    style.font-size: 22
  }
  dictionaryObserveUsecase -> observeExecutor: exact match batch lookup を依頼する {
    style.font-size: 22
  }
  observeExecutor -> dictionaryObserveUsecase: `candidateGroups` を返す {
    style.font-size: 22
  }
  dictionaryObserveUsecase -> dictionaryObserveStore: 読込済み状態と先頭選択を設定する {
    style.font-size: 22
  }
  dictionaryObserveStore -> dictionaryObserveView: loaded state を反映する {
    style.font-size: 22
  }
  user -> dictionaryObserveView: request を選択する {
    style.font-size: 22
  }
  dictionaryObserveView -> dictionaryObserveUsecase: 選択する (`select(index)`) {
    style.font-size: 22
  }
  dictionaryObserveUsecase -> dictionaryObserveStore: 選択 index を更新する {
    style.font-size: 22
  }
}
