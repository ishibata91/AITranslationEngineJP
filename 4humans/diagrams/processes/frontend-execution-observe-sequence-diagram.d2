title: "Frontend 実行観測画面シーケンス図"

executionObserveSequence: {
  shape: sequence_diagram

  user: "利用者"
  executionObserveScreen: "実行観測画面 (`ExecutionObserveScreen.svelte`)"
  executionObserveUsecase: "実行観測ユースケース (`ExecutionObserveScreenInput`)"
  executionObserveStore: "実行観測ストア (`ExecutionObserveScreenStore`)"
  observeLoader: "観測 loader (`createTauriExecutionObserveLoader()`)"
  executionObserveView: "実行観測ビュー (`ExecutionObserveView.svelte`)"

  user -> executionObserveScreen: 画面を開く {
    style.font-size: 22
  }
  executionObserveScreen -> executionObserveUsecase: 初期化する (`initialize()`) {
    style.font-size: 22
  }
  executionObserveUsecase -> executionObserveStore: loading にする {
    style.font-size: 22
  }
  executionObserveUsecase -> observeLoader: Tauri command を呼ぶ {
    style.font-size: 22
  }
  observeLoader -> executionObserveUsecase: progress / failure snapshot を返す {
    style.font-size: 22
  }
  executionObserveUsecase -> executionObserveStore: 確定 snapshot を保存する {
    style.font-size: 22
  }
  executionObserveStore -> executionObserveView: dashboard state を反映する {
    style.font-size: 22
  }
  user -> executionObserveView: Refresh を押す {
    style.font-size: 22
  }
  executionObserveView -> executionObserveUsecase: 再読込する (`refresh()`) {
    style.font-size: 22
  }
  executionObserveUsecase -> executionObserveStore: 既存 snapshot を維持して loading にする {
    style.font-size: 22
  }
  executionObserveUsecase -> observeLoader: 観測 snapshot を再取得する {
    style.font-size: 22
  }
  observeLoader -> executionObserveUsecase: 最新 snapshot または error を返す {
    style.font-size: 22
  }
  executionObserveUsecase -> executionObserveStore: snapshot 維持または更新と error を反映する {
    style.font-size: 22
  }
}
