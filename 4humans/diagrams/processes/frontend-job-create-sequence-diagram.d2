title: "Frontend ジョブ作成画面シーケンス図"

jobCreateSequence: {
  shape: sequence_diagram

  user: "利用者"
  jobCreateView: "ジョブ作成ビュー (`JobCreateView.svelte`)"
  jobCreateScreen: "ジョブ作成画面 (`JobCreateScreen.svelte`)"
  jobCreateUsecase: "ジョブ作成ユースケース (`JobCreateScreenInput`)"
  jobCreateStore: "ジョブ作成ストア (`JobCreateScreenStore`)"
  tauriGateway: "ジョブ作成 gateway (`createTauriJobCreateExecutor()`)"
  tauriBackend: "Tauri command (`create_job`)"

  user -> jobCreateView: 入力群と翻訳単位群を入力する {
    style.font-size: 22
  }
  user -> jobCreateView: ジョブ作成を押す {
    style.font-size: 22
  }
  jobCreateView -> jobCreateScreen: 送信 event (`submit`) を渡す {
    style.font-size: 22
  }
  jobCreateScreen -> jobCreateUsecase: 送信する (`submit()`) {
    style.font-size: 22
  }
  jobCreateUsecase -> jobCreateStore: 送信中状態へ置き換える {
    style.font-size: 22
  }
  jobCreateUsecase -> tauriGateway: 作成要求 (`JobCreateRequest`) を渡す {
    style.font-size: 22
  }
  tauriGateway -> tauriBackend: ジョブを作成する {
    style.font-size: 22
  }
  tauriBackend -> tauriGateway: 作成結果 (`JobCreateResult`) を返す {
    style.font-size: 22
  }
  tauriGateway -> jobCreateUsecase: 解決済み結果を返す {
    style.font-size: 22
  }
  jobCreateUsecase -> jobCreateStore: 結果反映状態へ置き換える {
    style.font-size: 22
  }
  jobCreateStore -> jobCreateView: 購読済み状態を反映する {
    style.font-size: 22
  }
}
