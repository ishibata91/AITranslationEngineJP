title: "Frontend 実行制御画面シーケンス図"

executionControlSequence: {
  shape: sequence_diagram

  user: "利用者"
  executionControlScreen: "実行制御画面 (`ExecutionControlScreen.svelte`)"
  executionControlUsecase: "実行制御ユースケース (`ExecutionControlScreenInput`)"
  tauriControlGateway: "Tauri 実行制御 gateway (`src/gateway/tauri/execution-control/index.ts`)"
  legacySnapshot: "確定 snapshot 直結 (`ExecutionControlSnapshot`) [旧]" {
    style.fill: "#fef2f2"
    style.stroke: "#dc2626"
    style.font-color: "#991b1b"
    style.stroke-dash: 4
  }
  tauriRegistration: "command 登録 (`src-tauri/src/lib.rs`)"
  tauriCommands: "command 入口 (`src-tauri/src/gateway/commands.rs`)"
  executionRuntime: "統合 runtime (`provider-failure-retry`)"
  executionObserveScreen: "実行観測画面 (`ExecutionObserveScreen.svelte`)"
  executionObserveUsecase: "実行観測ユースケース (`ExecutionObserveScreenInput`)"
  tauriObserveGateway: "Tauri 実行観測 gateway (`src/gateway/tauri/execution-observe/index.ts`)"

  user -> executionControlScreen: "画面を開く" {
    style.font-size: 22
  }
  executionControlScreen -> executionControlUsecase: "初期化する (`initialize()`)" {
    style.font-size: 22
  }
  executionControlUsecase -> legacySnapshot: "control state を直接読む [削除]" {
    style.font-size: 22
    style.stroke: "#dc2626"
    style.font-color: "#991b1b"
    style.stroke-dash: 4
  }
  legacySnapshot -> executionControlUsecase: "確定 snapshot を返す [削除]" {
    style.font-size: 22
    style.stroke: "#dc2626"
    style.font-color: "#991b1b"
    style.stroke-dash: 4
  }
  executionControlUsecase -> tauriControlGateway: "`loadSnapshot()` [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriControlGateway -> tauriRegistration: "`invoke(\"get_execution_control_snapshot\")` [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriRegistration -> tauriCommands: "登録済み command を呼ぶ [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriCommands -> executionRuntime: "現在の control state を読む [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  executionRuntime -> tauriCommands: "provider 非依存 snapshot を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriCommands -> tauriControlGateway: "control snapshot を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriControlGateway -> executionControlUsecase: "確定 snapshot を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  executionControlUsecase -> executionControlScreen: "画面 state を反映する" {
    style.font-size: 22
  }

  user -> executionControlScreen: "Pause / Resume / Retry / Cancel を押す" {
    style.font-size: 22
  }
  executionControlScreen -> executionControlUsecase: "操作を渡す" {
    style.font-size: 22
  }
  executionControlUsecase -> executionControlScreen: "pending action 中は操作を止める" {
    style.font-size: 22
  }
  executionControlUsecase -> tauriControlGateway: "`pauseCommand()` などを呼ぶ [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriControlGateway -> tauriRegistration: "`invoke(\"pause_execution\" など)` [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriRegistration -> tauriCommands: "登録済み command を呼ぶ [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriCommands -> executionRuntime: "状態遷移と scenario 切替を進める [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  executionRuntime -> tauriCommands: "制御後 snapshot を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriCommands -> tauriControlGateway: "制御結果を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriControlGateway -> executionControlUsecase: "更新済み snapshot を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  executionControlUsecase -> executionControlScreen: "control state を再計算する" {
    style.font-size: 22
  }

  user -> executionObserveScreen: "実行観測を再読込する" {
    style.font-size: 22
  }
  executionObserveScreen -> executionObserveUsecase: "`refresh()`" {
    style.font-size: 22
  }
  executionObserveUsecase -> tauriObserveGateway: "`loadSnapshot()` [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriObserveGateway -> tauriRegistration: "`invoke(\"get_execution_observe_snapshot\")` [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriRegistration -> tauriCommands: "observe command を呼ぶ [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriCommands -> executionRuntime: "同じ runtime から再観測する [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  executionRuntime -> tauriCommands: "observe snapshot と自動進行を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriCommands -> tauriObserveGateway: "dashboard snapshot を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  tauriObserveGateway -> executionObserveUsecase: "provider 非依存 snapshot を返す [追加]" {
    style.font-size: 22
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
  executionObserveUsecase -> executionObserveScreen: "再観測結果を表示する" {
    style.font-size: 22
  }
}
