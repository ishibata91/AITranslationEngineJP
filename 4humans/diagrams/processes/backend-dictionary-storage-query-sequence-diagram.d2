title: "Backend 辞書保存・検索シーケンス図"

dictionaryStorageQuerySequence: {
  shape: sequence_diagram

  frontend: "Tauri executor (`createTauriDictionaryObserveExecutor`)"
  rebuildCommand: "辞書再構築 command (`gateway::commands::rebuild_dictionary`)"
  lookupCommand: "辞書観測 command (`gateway::commands::lookup_dictionary`)"
  importUsecase: "辞書取込ユースケース (`ImportDictionaryUseCase`)"
  saveUsecase: "辞書保存ユースケース (`SaveImportedDictionaryUseCase`)"
  lookupUsecase: "辞書検索ユースケース (`LookupDictionaryUseCase`)"
  sqliteRepo: "SQLite 辞書 repository (`SqliteDictionaryRepository`)"
  masterDictionary: "辞書親 table (`master_dictionary`)"
  masterDictionaryEntry: "辞書 entry table (`master_dictionary_entry`)"
  snapshot: "検索結果スナップショット (`DictionaryLookupResult`)"

  frontend -> rebuildCommand: 辞書再構築要求 (`DictionaryImportRequestDto`) を渡す {
    style.font-size: 22
  }
  rebuildCommand -> importUsecase: 取込を実行する (`execute(request)`) {
    style.font-size: 22
  }
  importUsecase -> saveUsecase: 取込結果 (`DictionaryImportResultDto`) を渡す {
    style.font-size: 22
  }
  saveUsecase -> sqliteRepo: 取込済み辞書を保存する {
    style.font-size: 22
  }
  sqliteRepo -> masterDictionary: 親 row を insert する {
    style.font-size: 22
  }
  sqliteRepo -> masterDictionaryEntry: entry row 群を順序どおり insert する {
    style.font-size: 22
  }
  masterDictionaryEntry -> sqliteRepo: 保存結果を返す {
    style.font-size: 22
  }
  sqliteRepo -> saveUsecase: transaction 完了を返す {
    style.font-size: 22
  }
  saveUsecase -> rebuildCommand: 保存完了を返す {
    style.font-size: 22
  }
  rebuildCommand -> frontend: 取込結果 DTO を返す {
    style.font-size: 22
  }
  frontend -> lookupCommand: 検索要求 (`DictionaryLookupRequest`) を渡す {
    style.font-size: 22
  }
  lookupCommand -> lookupUsecase: 検索を実行する (`lookup(request)`) {
    style.font-size: 22
  }
  lookupUsecase -> lookupUsecase: 空 request を拒否し重複を集約する {
    style.font-size: 22
  }
  lookupUsecase -> sqliteRepo: exact match 検索を依頼する {
    style.font-size: 22
  }
  sqliteRepo -> masterDictionaryEntry: `source_text IN (...)` で候補 row を読む {
    style.font-size: 22
  }
  sqliteRepo -> masterDictionary: 辞書順序を参照する {
    style.font-size: 22
  }
  sqliteRepo -> lookupUsecase: 順序付き entry 群を返す {
    style.font-size: 22
  }
  lookupUsecase -> lookupUsecase: request 順へ `candidate_groups` を復元する {
    style.font-size: 22
  }
  lookupUsecase -> snapshot: 検索結果を渡す {
    style.font-size: 22
  }
  snapshot -> lookupCommand: 検索結果を返す {
    style.font-size: 22
  }
  lookupCommand -> frontend: `candidateGroups` を返す {
    style.font-size: 22
  }
}
