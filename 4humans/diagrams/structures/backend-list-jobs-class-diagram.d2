layout: dagre
direction: down

title: "Backend ジョブ一覧取得クラス図"

gateway: {
  shape: package
  label: "gateway"
  direction: down
  grid-cols: 1
  style.font-size: 22

  command: {
    shape: class
    label: "ジョブ一覧 command (`list_jobs()`)"
    style.font-size: 22
  }
}

application: {
  shape: package
  label: "application"
  direction: down
  grid-cols: 1
  style.font-size: 22

  usecase: {
    shape: class
    label: "ジョブ一覧ユースケース (`ListJobsUseCase`)"
    "+ 実行する": "`execute()`"
    "+ 一覧 result を組み立てる": ""
    style.font-size: 22
  }

  repoPort: {
    shape: class
    label: "repository port (`ListJobsRepository`)"
    "+ 保存済み job 一覧を返す": "`list_jobs()`"
    style.font-size: 22
  }

  resultDto: {
    shape: class
    label: "ジョブ一覧 DTO (`ListJobsResultDto`)"
    "+ UI 向け一覧を保持する": ""
    style.font-size: 22
  }

  usecase -> repoPort: 一覧取得を依頼する {
    style.font-size: 22
  }
  usecase -> resultDto: DTO を返す {
    style.font-size: 22
  }
}

domain: {
  shape: package
  label: "domain"
  direction: down
  grid-cols: 1
  style.font-size: 22

  listedJob: {
    shape: class
    label: "一覧用 job (`ListedJob`)"
    "+ `job_id` / `project_id` / `label` を持つ": ""
    style.font-size: 22
  }

  jobState: {
    shape: class
    label: "ジョブ状態 (`JobState`)"
    "+ pending / running / failed / completed": ""
    style.font-size: 22
  }

  listedJob -> jobState: 状態を参照する {
    style.font-size: 22
  }
}

infra: {
  shape: package
  label: "infra"
  direction: down
  grid-cols: 1
  style.font-size: 22

  repoImpl: {
    shape: class
    label: "memory job repository (`InMemoryJobRepository`)"
    "+ ListJobsRepository を実装する": ""
    style.font-size: 22
  }
}

gateway -> application
application -> domain
domain -> infra

gateway.command -> application.usecase: 一覧取得を呼ぶ {
  style.font-size: 22
}
infra.repoImpl -> application.repoPort: 実装する {
  style.font-size: 22
}
application.usecase -> domain.listedJob: 一覧用 job を扱う {
  style.font-size: 22
}
