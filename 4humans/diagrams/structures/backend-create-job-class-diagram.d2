layout: dagre
direction: down

title: "Backend ジョブ作成クラス図"

gateway: {
  shape: package
  label: "gateway"
  direction: down
  grid-cols: 1
  style.font-size: 22

  command: {
    shape: class
    label: "ジョブ作成 command (`create_job(request)`)"
    style.font-size: 22
  }
}

application: {
  shape: package
  label: "application"
  direction: down
  grid-cols: 1
  style.font-size: 22

  usecase: {
    shape: class
    label: "ジョブ作成ユースケース"
    "+ actual: `CreateJobUseCase`": ""
    "+ 作成要求を実行する": "`execute(request)`"
    style.font-size: 22
  }

  requestDto: {
    shape: class
    label: "ジョブ作成要求 DTO"
    "+ actual: `CreateJobRequestDto`": ""
    style.font-size: 22
  }

  resultDto: {
    shape: class
    label: "ジョブ作成結果 DTO"
    "+ actual: `CreateJobResultDto`": ""
    style.font-size: 22
  }

  repoPort: {
    shape: class
    label: "repository port"
    "+ actual: `CreateJobRepository`": ""
    "+ 作成済みジョブを保存する": "`save_created_job(created_job)`"
    style.font-size: 22
  }

  requestDto -> usecase: request を渡す {
    style.font-size: 22
  }
  usecase -> repoPort: 保存を依頼する {
    style.font-size: 22
  }
  repoPort -> resultDto: 結果 DTO を返す {
    style.font-size: 22
  }
}

domain: {
  shape: package
  label: "domain"
  direction: down
  grid-cols: 1
  style.font-size: 22

  translationUnit: {
    shape: class
    label: "翻訳単位"
    "+ actual: `TranslationUnit`": ""
    style.font-size: 22
  }

  sourceGroup: {
    shape: class
    label: "ジョブ作成入力群"
    "+ actual: `CreateJobSourceGroup`": ""
    style.font-size: 22
  }

  createReadyJob: {
    shape: class
    label: "準備完了ジョブ生成"
    "+ 準備完了ジョブを作る": "`create_ready_job(job_id, source_groups)`"
    style.font-size: 22
  }

  createdJob: {
    shape: class
    label: "作成済みジョブ"
    "+ actual: `CreatedJob`": ""
    style.font-size: 22
  }

  translationUnit -> sourceGroup: source group を組み立てる {
    style.font-size: 22
  }
  sourceGroup -> createReadyJob: 作成要求を渡す {
    style.font-size: 22
  }
  createReadyJob -> createdJob: 作成済みジョブを返す {
    style.font-size: 22
  }
}

infra: {
  shape: package
  label: "infra"
  direction: down
  grid-cols: 1
  style.font-size: 22

  repoImpl: {
    shape: class
    label: "memory job repository"
    "+ actual: `InMemoryJobRepository`": ""
    style.font-size: 22
  }
}

gateway.command -> application.usecase: 作成要求を渡す {
  style.font-size: 22
}
application.usecase -> domain.translationUnit: DTO を変換する {
  style.font-size: 22
}
application.usecase -> domain.createReadyJob: 準備完了ジョブを作る {
  style.font-size: 22
}
infra.repoImpl -> application.repoPort: 実装する {
  style.font-size: 22
}
