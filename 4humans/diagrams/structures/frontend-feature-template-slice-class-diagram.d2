layout: dagre
direction: down

title: "Frontend テンプレート slice クラス図"

ui: {
  shape: package
  label: "UI"
  direction: down
  style.font-size: 22

  screen: {
    shape: class
    label: "テンプレート画面 (`FeatureTemplateScreen.svelte`)"
    "- 初期化と event 転送を行う": ""
    style.font-size: 22
  }

  view: {
    shape: class
    label: "テンプレートビュー (`FeatureTemplateView.svelte`)"
    "- query 編集と event 発火を行う": ""
    style.font-size: 22
  }

  screen -> view: 描画する {
    style.font-size: 22
  }
}

application: {
  shape: package
  label: "application"
  direction: down
  style.font-size: 22

  usecase: {
    shape: class
    label: "テンプレートユースケース (`FeatureTemplateScreenInput` / `createFeatureTemplateScreenUsecase()`)"
    "+ 読込・再試行・選択・filter 更新を扱う": ""
    style.font-size: 22
  }

  featureFoundation: {
    shape: class
    label: "汎用画面基盤 (`createFeatureScreenUsecase()` / `createFeatureScreenStore()`)"
    style.font-size: 22
  }

  contract: {
    shape: class
    label: "テンプレート contract (`FeatureTemplateData` / `FeatureTemplateItem` / `FeatureTemplateQuery`)"
    style.font-size: 22
  }

  store: {
    shape: class
    label: "テンプレートストア (`FeatureTemplateScreenStore`)"
    "+ filter / data / selection を保持する": ""
    style.font-size: 22
  }

  usecase -> featureFoundation: 読込状態遷移を再利用する {
    style.font-size: 22
  }
  contract -> store: data / filter / selection を反映する {
    style.font-size: 22
  }
}

gateway: {
  shape: package
  label: "gateway"
  direction: down
  style.font-size: 22

  templateGateway: {
    shape: class
    label: "テンプレート gateway (`createTauriFeatureTemplateGateway()`)"
    "- query 付き `load(request)` を呼ぶ": ""
    style.font-size: 22
  }

  featureGateway: {
    shape: class
    label: "汎用 Tauri gateway (`createTauriFeatureScreenGateway()`)"
    style.font-size: 22
  }

  templateGateway -> featureGateway: 汎用 `load(request)` を使う {
    style.font-size: 22
  }
}

ui.view -> application.usecase: event を渡す {
  style.font-size: 22
}
ui.screen -> application.usecase: 初期化する {
  style.font-size: 22
}
application.usecase -> gateway.templateGateway: query 付き読込を依頼する {
  style.font-size: 22
}
gateway.featureGateway -> application.contract: data を返す {
  style.font-size: 22
}
application.store -> ui.view: 購読済み状態を渡す {
  style.font-size: 22
}
