layout: dagre
direction: down

title: "Frontend 実行制御 slice クラス図"

ui: {
  shape: package
  label: "UI"
  direction: down
  style.font-size: 22

  screen: {
    shape: class
    label: "実行制御画面 (`ExecutionControlScreen.svelte`)"
    "+ 初期化で usecase を起動する": ""
    style.font-size: 22
  }

  view: {
    shape: class
    label: "実行制御ビュー (`ExecutionControlView.svelte`)"
    "+ pause / resume / retry / cancel を発火する": ""
    style.font-size: 22
  }

  screen -> view: "描画する" {
    style.font-size: 22
  }
}

application: {
  shape: package
  label: "application"
  direction: down
  style.font-size: 22

  usecase: {
    shape: class
    label: "実行制御ユースケース (`ExecutionControlScreenInput` / `createExecutionControlScreenUsecase()`)"
    "+ provider 非依存の操作だけを見る": ""
    "+ 初期化と pending action を扱う": ""
    style.font-size: 22
  }

  store: {
    shape: class
    label: "実行制御ストア (`ExecutionControlScreenStore`)"
    "+ control state / failure / pending action を保持する": ""
    style.font-size: 22
  }

  legacySnapshot: {
    shape: class
    label: "確定 snapshot 直結 (`ExecutionControlSnapshot`) [旧]"
    "- frontend 内で完結して読まれる": ""
    style.font-size: 22
    style.fill: "#fef2f2"
    style.stroke: "#dc2626"
    style.font-color: "#991b1b"
    style.stroke-dash: 4
  }
}

composition: {
  shape: package
  label: "composition"
  direction: down
  style.font-size: 22

  main: {
    shape: class
    label: "構成ルート (`src/main.ts`)"
    "+ Tauri gateway を usecase へ注入する": ""
    "+ UI 境界へ provider detail を出さない": ""
    style.font-size: 22
    style.fill: "#ecfdf5"
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
}

gateway: {
  shape: package
  label: "frontend gateway"
  direction: down
  style.font-size: 22

  tauriGateway: {
    shape: class
    label: "Tauri 実行制御 gateway (`src/gateway/tauri/execution-control/index.ts`)"
    "+ `loadSnapshot()`": ""
    "+ `pauseCommand()` / `resumeCommand()`": ""
    "+ `retryCommand()` / `cancelCommand()`": ""
    "+ `invoke(...)` だけを持つ thin adapter": ""
    style.font-size: 22
    style.fill: "#ecfdf5"
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
}

backend: {
  shape: package
  label: "tauri backend"
  direction: down
  style.font-size: 22

  lib: {
    shape: class
    label: "command 登録 (`src-tauri/src/lib.rs`)"
    "+ `invoke_handler(...)` に実行制御 command を束ねる": ""
    style.font-size: 22
    style.fill: "#ecfdf5"
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }

  commands: {
    shape: class
    label: "command 入口 (`src-tauri/src/gateway/commands.rs`)"
    "+ `get_execution_control_snapshot()`": ""
    "+ `pause_execution()` / `resume_execution()`": ""
    "+ `retry_execution()` / `cancel_execution()`": ""
    "+ `get_execution_observe_snapshot()`": ""
    style.font-size: 22
    style.fill: "#ecfdf5"
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }

  runtime: {
    shape: class
    label: "統合 runtime (`provider-failure-retry` fixture / state)"
    "+ provider 選択と実行 mode を保持する": ""
    "+ control 遷移と observe 再観測を共有する": ""
    style.font-size: 22
    style.fill: "#ecfdf5"
    style.stroke: "#16a34a"
    style.font-color: "#166534"
  }
}

ui.view -> application.usecase: "操作を渡す" {
  style.font-size: 22
}
ui.screen -> application.usecase: "初期化する" {
  style.font-size: 22
}
application.usecase -> application.store: "画面 state を更新する" {
  style.font-size: 22
}
application.store -> ui.view: "購読済み状態を渡す" {
  style.font-size: 22
}

application.usecase -> application.legacySnapshot: "確定 snapshot を直接読む [削除]" {
  style.font-size: 22
  style.stroke: "#dc2626"
  style.font-color: "#991b1b"
  style.stroke-dash: 4
}
application.legacySnapshot -> application.store: "frontend 内で直接反映する [削除]" {
  style.font-size: 22
  style.stroke: "#dc2626"
  style.font-color: "#991b1b"
  style.stroke-dash: 4
}

composition.main -> application.usecase: "gateway を注入する [追加]" {
  style.font-size: 22
  style.stroke: "#16a34a"
  style.font-color: "#166534"
}
composition.main -> gateway.tauriGateway: "Tauri adapter を組み立てる [追加]" {
  style.font-size: 22
  style.stroke: "#16a34a"
  style.font-color: "#166534"
}
application.usecase -> gateway.tauriGateway: "provider 非依存 port として呼ぶ [追加]" {
  style.font-size: 22
  style.stroke: "#16a34a"
  style.font-color: "#166534"
}
gateway.tauriGateway -> backend.lib: "command 名で `invoke(...)` する [追加]" {
  style.font-size: 22
  style.stroke: "#16a34a"
  style.font-color: "#166534"
}
backend.lib -> backend.commands: "登録済み command へ配線する [追加]" {
  style.font-size: 22
  style.stroke: "#16a34a"
  style.font-color: "#166534"
}
backend.commands -> backend.runtime: "state 読込 / 制御 / observe 再観測を進める [追加]" {
  style.font-size: 22
  style.stroke: "#16a34a"
  style.font-color: "#166534"
}
