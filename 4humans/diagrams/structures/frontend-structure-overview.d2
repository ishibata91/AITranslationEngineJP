layout: elk
direction: right

title: "Frontend `src/` 構造 overview"

app: {
  shape: package
  label: "アプリ起動"
  direction: down
  style.font-size: 22

  entrypoint: {
    shape: class
    label: "起動と配線 (`main.ts` / `App.svelte` / `AppShell.svelte`)"
    style.font-size: 22
  }

  optionalPreviewCompose: {
    shape: class
    label: "preview optional compose (`AppShell.svelte`)"
    style.font-size: 22
  }
}

mountedSlices: {
  shape: package
  label: "配線済み画面 slice"
  direction: down
  style.font-size: 22

  jobListSlice: {
    shape: class
    label: "ジョブ一覧 slice"
    link: "./frontend-job-list-slice-class-diagram.svg"
    style.font-size: 22
  }

  jobCreateSlice: {
    shape: class
    label: "ジョブ作成 slice"
    link: "./frontend-job-create-slice-class-diagram.svg"
    style.font-size: 22
  }

  dictionaryObserveSlice: {
    shape: class
    label: "辞書観測 slice (条件付き compose)"
    link: "./frontend-dictionary-observe-slice-class-diagram.svg"
    style.font-size: 22
  }

  personaObserveSlice: {
    shape: class
    label: "ペルソナ観測 slice (条件付き compose)"
    link: "./frontend-persona-observe-slice-class-diagram.svg"
    style.font-size: 22
  }

  bootstrapSlice: {
    shape: class
    label: "起動状態 slice"
    link: "./frontend-bootstrap-status-slice-class-diagram.svg"
    style.font-size: 22
  }

  translationPreviewSlice: {
    shape: class
    label: "翻訳 preview slice (条件付き compose)"
    style.font-size: 22
  }

  executionControlSlice: {
    shape: class
    label: "実行制御 slice (未配線)"
    link: "./frontend-execution-control-slice-class-diagram.svg"
    style.font-size: 22
  }
}

foundations: {
  shape: package
  label: "再利用基盤"
  direction: down
  style.font-size: 22

  featureTemplateSlice: {
    shape: class
    label: "テンプレート slice (未配線)"
    link: "./frontend-feature-template-slice-class-diagram.svg"
    style.font-size: 22
  }
}

gatewayLayer: {
  shape: package
  label: "gateway"
  direction: down
  style.font-size: 22

  jobListGateway: {
    shape: class
    label: "一覧取得 gateway"
    link: "./frontend-job-list-slice-class-diagram.svg"
    style.font-size: 22
  }

  jobCreateGateway: {
    shape: class
    label: "作成 gateway"
    link: "./frontend-job-create-slice-class-diagram.svg"
    style.font-size: 22
  }

  bootstrapGateway: {
    shape: class
    label: "起動状態 gateway"
    link: "./frontend-bootstrap-status-slice-class-diagram.svg"
    style.font-size: 22
  }

  featureTemplateGateway: {
    shape: class
    label: "テンプレート gateway"
    link: "./frontend-feature-template-slice-class-diagram.svg"
    style.font-size: 22
  }

  dictionaryObserveExecutor: {
    shape: class
    label: "辞書観測 executor"
    link: "./frontend-dictionary-observe-slice-class-diagram.svg"
    style.font-size: 22
  }

  personaObserveExecutor: {
    shape: class
    label: "ペルソナ観測 executor"
    link: "./frontend-persona-observe-slice-class-diagram.svg"
    style.font-size: 22
  }

  translationPreviewExecutor: {
    shape: class
    label: "翻訳 preview executor"
    style.font-size: 22
  }

  executionControlBoundary: {
    shape: class
    label: "実行制御 snapshot / command boundary"
    link: "./frontend-execution-control-slice-class-diagram.svg"
    style.font-size: 22
  }
}

contracts: {
  shape: package
  label: "shared contract"
  direction: down
  style.font-size: 22

  jobContract: {
    shape: class
    label: "job contract"
    style.font-size: 22
  }

  bootstrapContract: {
    shape: class
    label: "bootstrap contract"
    style.font-size: 22
  }

  featureTemplateContract: {
    shape: class
    label: "feature-template contract"
    style.font-size: 22
  }

  translationPreviewContract: {
    shape: class
    label: "translation-preview contract"
    style.font-size: 22
  }
}

app.entrypoint -> mountedSlices: props を渡して画面 slice を配線する {
  style.font-size: 22
}
app.optionalPreviewCompose -> mountedSlices.translationPreviewSlice: store と usecase がある時だけ preview を compose する {
  style.font-size: 22
}
mountedSlices -> gatewayLayer: 各 slice から gateway を呼ぶ {
  style.font-size: 22
}
mountedSlices -> contracts: 画面 slice が contract を扱う {
  style.font-size: 22
}
foundations.featureTemplateSlice -> gatewayLayer.featureTemplateGateway: テンプレート読込を依頼する {
  style.font-size: 22
}
foundations.featureTemplateSlice -> contracts.featureTemplateContract: query と data を扱う {
  style.font-size: 22
}
mountedSlices.dictionaryObserveSlice -> gatewayLayer.dictionaryObserveExecutor: 観測 request を渡す {
  style.font-size: 22
}
mountedSlices.personaObserveSlice -> gatewayLayer.personaObserveExecutor: 観測 request を渡す {
  style.font-size: 22
}
mountedSlices.translationPreviewSlice -> gatewayLayer.translationPreviewExecutor: preview observe / refresh request を渡す {
  style.font-size: 22
}
mountedSlices.translationPreviewSlice -> contracts.translationPreviewContract: preview item と filter state を扱う {
  style.font-size: 22
}
mountedSlices.executionControlSlice -> gatewayLayer.executionControlBoundary: stable control state と command 結果を受け渡す {
  style.font-size: 22
}
