direction: right

title: "Backend bootstrap-status class diagram"

gateway: {
  shape: package
  label: "gateway"

  command: {
    shape: class
    label: "起動状態 command (`get_bootstrap_status()`)"
  }
}

application: {
  shape: package
  label: "application"

  usecase: {
    shape: class
    label: "起動状態ユースケース (`GetBootstrapStatusUseCase`)\n+ 実行する (`execute()`) "
  }

  resultDto: {
    shape: class
    label: "起動状態 DTO (`BootstrapStatusDto`)"
  }

  runtimePort: {
    shape: class
    label: "runtime port (`RuntimeInfoProvider`)\n+ backend 版を返す (`backend_version()`)"
  }
}

domain: {
  shape: package
  label: "domain"

  bootstrapStatus: {
    shape: class
    label: "起動状態 (`BootstrapStatus`)"
  }
}

infra: {
  shape: package
  label: "infra"

  runtimeImpl: {
    shape: class
    label: "runtime provider (`CargoRuntimeInfoProvider`)"
  }
}

gateway.command -> application.usecase: 起動状態取得を呼ぶ
application.usecase -> application.runtimePort: 版情報を依頼する
infra.runtimeImpl -> application.runtimePort: 実装する
application.usecase -> domain.bootstrapStatus: 状態を組み立てる
application.usecase -> application.resultDto: DTO を返す
