direction: right

title: "Backend dictionary-storage-query class diagram"

application: {
  shape: package
  label: "application"

  saveUsecase: {
    shape: class
    label: "辞書保存ユースケース (`SaveImportedDictionaryUseCase`)\n+ 取込済み辞書を保存する (`execute(imported_dictionary)`) "
  }

  lookupUsecase: {
    shape: class
    label: "辞書検索ユースケース (`LookupDictionaryUseCase`)\n+ 再利用辞書候補を検索する (`lookup(request)`) "
  }

  queryRepository: {
    shape: class
    label: "辞書 query repository (`DictionaryQueryRepository`)\n+ 取込済み master dictionary を保存する (`save_imported_master_dictionary(imported_dictionary)`) \n+ source_text 群で再利用 entry を検索する (`lookup_reusable_entries_by_source_texts(source_texts)`) "
  }

  importResultDto: {
    shape: class
    label: "辞書取込結果 DTO (`DictionaryImportResultDto`)"
  }

  lookupRequestDto: {
    shape: class
    label: "辞書検索要求 DTO (`DictionaryLookupRequest`)"
  }

  lookupResultDto: {
    shape: class
    label: "辞書検索結果 DTO (`DictionaryLookupResult`)"
  }
}

sharedDto: {
  shape: package
  label: "shared DTO"

  reusableEntry: {
    shape: class
    label: "再利用辞書 entry (`ReusableDictionaryEntryDto`)"
  }
}

infra: {
  shape: package
  label: "infra"

  sqliteRepository: {
    shape: class
    label: "SQLite 辞書 repository (`SqliteDictionaryRepository`)"
  }

  masterDictionaryTable: {
    shape: sql_table
    label: "master dictionary table (`master_dictionary`)"
  }

  masterDictionaryEntryTable: {
    shape: sql_table
    label: "master dictionary entry table (`master_dictionary_entry`)"
  }
}

application.saveUsecase -> application.importResultDto: 取込済み辞書を受け取る
application.saveUsecase -> application.queryRepository: 保存を依頼する
application.lookupUsecase -> application.lookupRequestDto: 検索要求を受け取る
application.lookupUsecase -> application.queryRepository: exact match 検索を依頼する
application.lookupUsecase -> application.lookupResultDto: request 順の結果を返す
application.lookupUsecase -> sharedDto.reusableEntry: 候補群を束ねる
infra.sqliteRepository -> application.queryRepository: 実装する
infra.sqliteRepository -> infra.masterDictionaryTable: parent row を transaction で保存する
infra.sqliteRepository -> infra.masterDictionaryEntryTable: ordered entry row を transaction で保存する
infra.sqliteRepository -> sharedDto.reusableEntry: query row を DTO に戻す
infra.masterDictionaryEntryTable -> infra.masterDictionaryTable: `master_dictionary_id` で従属する
