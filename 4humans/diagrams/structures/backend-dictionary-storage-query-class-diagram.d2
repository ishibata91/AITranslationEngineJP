layout: dagre
direction: down

title: "Backend 辞書保存・検索クラス図"

gateway: {
  shape: package
  label: "gateway"
  direction: down
  grid-cols: 1
  style.font-size: 22

  rebuildCommand: {
    shape: class
    label: "辞書再構築 command"
    "+ actual: `rebuild_dictionary(request)`": ""
    style.font-size: 22
  }

  lookupCommand: {
    shape: class
    label: "辞書観測 command"
    "+ actual: `lookup_dictionary(request)`": ""
    style.font-size: 22
  }
}

application: {
  shape: package
  label: "application"
  direction: down
  grid-cols: 1
  style.font-size: 22

  importResultDto: {
    shape: class
    label: "辞書取込結果 DTO"
    "+ actual: `DictionaryImportResultDto`": ""
    style.font-size: 22
  }

  saveUsecase: {
    shape: class
    label: "辞書保存ユースケース"
    "+ actual: `SaveImportedDictionaryUseCase`": ""
    "+ 取込済み辞書を保存する": "`execute(imported_dictionary)`"
    style.font-size: 22
  }

  queryRepository: {
    shape: class
    label: "辞書 query repository"
    "+ actual: `DictionaryQueryRepository`": ""
    "+ 取込済み辞書を保存する": "`save_imported_master_dictionary(imported_dictionary)`"
    "+ source_text 群で entry を検索する": "`lookup_reusable_entries_by_source_texts(source_texts)`"
    style.font-size: 22
  }

  lookupRequestDto: {
    shape: class
    label: "辞書検索要求 DTO"
    "+ actual: `DictionaryLookupRequest`": ""
    style.font-size: 22
  }

  lookupUsecase: {
    shape: class
    label: "辞書検索ユースケース"
    "+ actual: `LookupDictionaryUseCase`": ""
    "+ 再利用辞書候補を検索する": "`lookup(request)`"
    style.font-size: 22
  }

  lookupResultDto: {
    shape: class
    label: "辞書検索結果 DTO"
    "+ actual: `DictionaryLookupResult`": ""
    style.font-size: 22
  }

  importResultDto -> saveUsecase: 取込済み辞書を渡す {
    style.font-size: 22
  }
  saveUsecase -> queryRepository: 保存を依頼する {
    style.font-size: 22
  }
  lookupRequestDto -> lookupUsecase: 検索要求を渡す {
    style.font-size: 22
  }
  lookupUsecase -> queryRepository: exact match 検索を依頼する {
    style.font-size: 22
  }
  queryRepository -> lookupResultDto: request 順の結果を返す {
    style.font-size: 22
  }
}

sharedDto: {
  shape: package
  label: "shared DTO"
  direction: down
  grid-cols: 1
  style.font-size: 22

  reusableEntry: {
    shape: class
    label: "再利用辞書 entry"
    "+ actual: `ReusableDictionaryEntryDto`": ""
    style.font-size: 22
  }
}

infra: {
  shape: package
  label: "infra"
  direction: down
  grid-cols: 1
  style.font-size: 22

  sqliteRepository: {
    shape: class
    label: "SQLite 辞書 repository"
    "+ actual: `SqliteDictionaryRepository`": ""
    style.font-size: 22
  }

  masterDictionaryTable: {
    shape: sql_table
    label: "辞書親 table"
    "actual: `master_dictionary`": ""
    style.font-size: 22
  }

  masterDictionaryEntryTable: {
    shape: sql_table
    label: "辞書 entry table"
    "actual: `master_dictionary_entry`": ""
    style.font-size: 22
  }

  masterDictionaryEntryTable -> masterDictionaryTable: `master_dictionary_id` で従属する {
    style.font-size: 22
  }
}

gateway -> application
application -> sharedDto
sharedDto -> infra

gateway.rebuildCommand -> application.importResultDto: 再構築結果を渡す {
  style.font-size: 22
}
gateway.lookupCommand -> application.lookupRequestDto: 検索要求を渡す {
  style.font-size: 22
}
application.lookupResultDto -> sharedDto.reusableEntry: 候補群を束ねる {
  style.font-size: 22
}
infra.sqliteRepository -> application.queryRepository: 実装する {
  style.font-size: 22
}
infra.sqliteRepository -> infra.masterDictionaryTable: 親 row を保存する {
  style.font-size: 22
}
infra.sqliteRepository -> infra.masterDictionaryEntryTable: ordered entry row を保存する {
  style.font-size: 22
}
infra.sqliteRepository -> sharedDto.reusableEntry: query row を DTO に戻す {
  style.font-size: 22
}
