layout: dagre
direction: down

title: "Backend job persona 永続化クラス図"

application: {
  shape: package
  label: "application"
  direction: down
  grid-cols: 1
  style.font-size: 22

  persistUsecase: {
    shape: class
    label: "job persona 永続化ユースケース"
    "+ actual: `PersistJobPersonaUseCase`": ""
    "+ 保存要求を検証して save/read を直列実行する": "`execute(request)`"
    style.font-size: 22
  }

  storagePort: {
    shape: class
    label: "job persona storage port"
    "+ actual: `JobPersonaStoragePort`": ""
    "+ snapshot を置換保存する": "`save_job_persona(request)`"
    "+ snapshot を読む": "`read_job_persona(request)`"
    style.font-size: 22
  }

  persistUsecase -> storagePort: save/read を順に依頼する {
    style.font-size: 22
  }
}

dto: {
  shape: package
  label: "application DTO"
  direction: down
  grid-cols: 1
  style.font-size: 22

  saveRequest: {
    shape: class
    label: "保存要求 DTO"
    "+ actual: `JobPersonaSaveRequestDto`": ""
    style.font-size: 22
  }

  entry: {
    shape: class
    label: "job persona entry DTO"
    "+ actual: `JobPersonaEntryDto`": ""
    style.font-size: 22
  }

  readRequest: {
    shape: class
    label: "読込要求 DTO"
    "+ actual: `JobPersonaReadRequestDto`": ""
    style.font-size: 22
  }

  readResult: {
    shape: class
    label: "読込結果 DTO"
    "+ actual: `JobPersonaReadResultDto`": ""
    style.font-size: 22
  }

  saveRequest -> entry: request 順の entries を束ねる {
    style.font-size: 22
  }
  readRequest -> readResult: 同じ job_id の結果を返す {
    style.font-size: 22
  }
  readResult -> entry: 保存順の entries を返す {
    style.font-size: 22
  }
}

infra: {
  shape: package
  label: "infra"
  direction: down
  grid-cols: 1
  style.font-size: 22

  repository: {
    shape: class
    label: "SQLite job persona repository"
    "+ actual: `SqliteJobPersonaRepository`": ""
    "+ 既存 rows を削除して snapshot を保存する": "`save_job_persona(request)`"
    "+ `id` 順で snapshot を読む": "`read_job_persona(request)`"
    style.font-size: 22
  }

  executionCache: {
    shape: class
    label: "execution cache SQLite"
    style.font-size: 22
  }
}

storage: {
  shape: package
  label: "job persona storage"
  direction: down
  grid-cols: 1
  style.font-size: 22

  jobPersonaEntryTable: {
    shape: sql_table
    label: "job persona entry"
    "actual: `job_persona_entry`": ""
    "id: INTEGER": "primary_key"
    "job_id: INTEGER": "foreign_key -> `translation_job.id`"
    "npc_id: INTEGER": "foreign_key -> `npc.id`"
    "source_type: TEXT": "not_null"
    "npc_form_id: TEXT": "not_null"
    "race: TEXT": "not_null"
    "sex: TEXT": "not_null"
    "voice: TEXT": "not_null"
    "persona_text: TEXT": "not_null"
    style.font-size: 22
  }
}

application -> dto
dto -> infra
infra -> storage

application.persistUsecase -> dto.saveRequest: 保存要求を検証する {
  style.font-size: 22
}
application.persistUsecase -> dto.readRequest: 読込要求を組み立てる {
  style.font-size: 22
}
application.storagePort -> dto.saveRequest: snapshot を受け取る {
  style.font-size: 22
}
application.storagePort -> dto.readRequest: 読込要求を受け取る {
  style.font-size: 22
}
application.storagePort -> dto.readResult: 保存後 snapshot を返す {
  style.font-size: 22
}
infra.repository -> application.storagePort: 実装する {
  style.font-size: 22
}
infra.repository -> infra.executionCache: connection と transaction を開く {
  style.font-size: 22
}
infra.executionCache -> storage.jobPersonaEntryTable: `JOB_PERSONA_ENTRY` を保持する {
  style.font-size: 22
}
infra.repository -> storage.jobPersonaEntryTable: job-local rows を置換保存する {
  style.font-size: 22
}
infra.repository -> storage.jobPersonaEntryTable: `ORDER BY id ASC` で読む {
  style.font-size: 22
}
