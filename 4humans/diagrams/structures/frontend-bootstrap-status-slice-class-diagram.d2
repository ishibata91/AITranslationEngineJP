layout: dagre
direction: down

title: "Frontend 起動状態 slice クラス図"

ui: {
  shape: package
  label: "UI"
  direction: down
  style.font-size: 22

  screen: {
    shape: class
    label: "起動状態画面 (`BootstrapStatusScreen.svelte`)"
    "- 初期化と event 転送を行う": ""
    style.font-size: 22
  }

  view: {
    shape: class
    label: "起動状態ビュー (`BootstrapStatusView.svelte`)"
    "- 状態表示と event 発火を行う": ""
    style.font-size: 22
  }

  screen -> view: 描画する {
    style.font-size: 22
  }
}

application: {
  shape: package
  label: "application"
  direction: down
  style.font-size: 22

  usecase: {
    shape: class
    label: "起動状態ユースケース (`BootstrapStatusScreenInput` / `createBootstrapStatusScreenUsecase()`)"
    "+ 初期化・再読込・再試行・選択を扱う": ""
    style.font-size: 22
  }

  featureFoundation: {
    shape: class
    label: "汎用画面基盤 (`createFeatureScreenUsecase()`)"
    "+ 読込状態遷移を再利用する": ""
    style.font-size: 22
  }

  contract: {
    shape: class
    label: "起動状態 contract (`BootstrapStatus` / `BootstrapStatusField`)"
    style.font-size: 22
  }

  store: {
    shape: class
    label: "起動状態ストア (`BootstrapStatusScreenStore`)"
    "+ 読込状態と選択を保持する": ""
    style.font-size: 22
  }

  usecase -> featureFoundation: 読込状態遷移を再利用する {
    style.font-size: 22
  }
  contract -> store: 読込済み状態を反映する {
    style.font-size: 22
  }
}

gateway: {
  shape: package
  label: "gateway"
  direction: down
  style.font-size: 22

  bootstrapGateway: {
    shape: class
    label: "起動状態 gateway (`createTauriBootstrapStatusGateway()`)"
    "- 起動状態を取得する": ""
    style.font-size: 22
  }

  featureGateway: {
    shape: class
    label: "汎用 Tauri gateway (`createTauriFeatureScreenGateway()`)"
    "- `load()` で command を呼ぶ": ""
    style.font-size: 22
  }

  bootstrapGateway -> featureGateway: 汎用 `load()` を使う {
    style.font-size: 22
  }
}

ui.view -> application.usecase: event を渡す {
  style.font-size: 22
}
ui.screen -> application.usecase: 初期化する {
  style.font-size: 22
}
application.usecase -> gateway.bootstrapGateway: 起動状態取得を依頼する {
  style.font-size: 22
}
gateway.featureGateway -> application.contract: 起動状態を返す {
  style.font-size: 22
}
application.store -> ui.view: 購読済み状態を渡す {
  style.font-size: 22
}
