layout: elk
direction: right

title: "Backend master persona 再構築クラス図"

application: {
  shape: package
  label: "application"
  direction: down
  style.font-size: 22

  rebuildUsecase: {
    shape: class
    label: "master persona 再構築ユースケース (`RebuildMasterPersonaUseCase`)"
    "+ base-game NPC 入力から master persona を再構築する": "`execute(request)`"
    style.font-size: 22
  }

  builderPort: {
    shape: class
    label: "master persona builder port (`MasterPersonaBuilderPort`)"
    "+ 保存要求を構築する": "`build_master_persona_save_request(request)`"
    style.font-size: 22
  }

  storagePort: {
    shape: class
    label: "master persona storage port (`MasterPersonaStoragePort`)"
    "+ master persona を保存する": "`save_master_persona(request)`"
    "+ master persona を読む": "`read_master_persona(request)`"
    style.font-size: 22
  }

  rebuildRequest: {
    shape: class
    label: "base-game NPC 再構築要求 (`BaseGameNpcRebuildRequest`)"
    style.font-size: 22
  }

  rebuildEntry: {
    shape: class
    label: "base-game NPC 再構築 entry (`BaseGameNpcRebuildEntry`)"
    style.font-size: 22
  }
}

dto: {
  shape: package
  label: "application DTO"
  direction: down
  style.font-size: 22

  saveRequest: {
    shape: class
    label: "master persona 保存要求 DTO (`MasterPersonaSaveRequestDto`)"
    style.font-size: 22
  }

  readRequest: {
    shape: class
    label: "master persona 読込要求 DTO (`MasterPersonaReadRequestDto`)"
    style.font-size: 22
  }

  readResult: {
    shape: class
    label: "master persona 読込結果 DTO (`MasterPersonaReadResultDto`)"
    style.font-size: 22
  }

  masterEntry: {
    shape: class
    label: "master persona entry DTO (`MasterPersonaEntryDto`)"
    style.font-size: 22
  }
}

infra: {
  shape: package
  label: "infra"
  direction: down
  style.font-size: 22

  baseGameBuilder: {
    shape: class
    label: "base-game NPC master persona builder (`BaseGameNpcMasterPersonaBuilder`)"
    "+ base-game 入力を保存要求へ変換する": "`build_master_persona_save_request(request)`"
    style.font-size: 22
  }
}

application.rebuildUsecase -> application.rebuildRequest: base-game NPC 入力を受け取る {
  style.font-size: 22
}
application.rebuildRequest -> application.rebuildEntry: ordered entry 群を束ねる {
  style.font-size: 22
}
application.rebuildUsecase -> application.builderPort: 保存要求の構築を依頼する {
  style.font-size: 22
}
application.rebuildUsecase -> dto.readRequest: `persona_name` から読込要求を組み立てる {
  style.font-size: 22
}
application.rebuildUsecase -> application.storagePort: save / read を順に依頼する {
  style.font-size: 22
}
application.builderPort -> dto.saveRequest: save contract を返す {
  style.font-size: 22
}
infra.baseGameBuilder -> application.builderPort: 実装する {
  style.font-size: 22
}
infra.baseGameBuilder -> application.rebuildRequest: `source_type` と必須 field を検証する {
  style.font-size: 22
}
infra.baseGameBuilder -> dto.masterEntry: entry を順序そのままで写す {
  style.font-size: 22
}
dto.saveRequest -> dto.masterEntry: `entries` として保存する {
  style.font-size: 22
}
dto.readResult -> dto.masterEntry: 読み戻し entry 群を束ねる {
  style.font-size: 22
}
application.storagePort -> dto.saveRequest: 保存要求を受け取る {
  style.font-size: 22
}
application.storagePort -> dto.readRequest: 読込要求を受け取る {
  style.font-size: 22
}
application.storagePort -> dto.readResult: 保存後の master persona を返す {
  style.font-size: 22
}
