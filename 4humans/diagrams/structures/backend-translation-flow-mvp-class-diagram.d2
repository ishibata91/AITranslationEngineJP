layout: dagre
direction: down

title: "Backend translation flow MVP orchestration クラス図"

gatewaySection: {
  shape: class
  label: "gateway orchestration"
  "+ helper: `run_translation_flow_mvp_orchestration`": ""
  "+ request DTO: `RunTranslationFlowMvpRequestDto`": ""
  "+ `job_id` / `source_type` / NPC metadata": ""
  "+ `translation_unit` / `embedded_elements`": ""
  style.font-size: 22
}

phaseSection: {
  shape: class
  label: "application phase"
  "+ word phase: `RunWordTranslationPhaseUseCase`": ""
  "+ persona phase: `RunNpcPersonaGenerationPhaseUseCase`": ""
  "+ runtime caller: `PersonaGenerationRuntimePort` consumer": ""
  "+ body phase: `RunBodyTranslationPhaseUseCase`": ""
  "+ persona request: `NpcPersonaGenerationPhaseRequestDto`": ""
  "+ body request: `BodyTranslationPhaseRequestDto`": ""
  style.font-size: 22
}

dtoSection: {
  shape: class
  label: "application DTO"
  "+ `TranslationUnitDto` / `ReusableDictionaryEntryDto`": ""
  "+ `ProviderSelectionDto` / `ExecutionControlStateDto`": ""
  "+ `ExecutionControlFailureDto`": ""
  "+ `PersonaGenerationRuntimeRequestDto`": ""
  "+ `PersonaGenerationRuntimeResultDto` / `JobPersonaEntryDto`": ""
  "+ `EmbeddedElementPolicyDto` / `EmbeddedElementDescriptorDto`": ""
  "+ `TranslationPhaseHandoffDto` / `TranslationPreviewItemDto`": ""
  style.font-size: 22
}

portSection: {
  shape: class
  label: "ports / adapters"
  "+ `DictionaryLookupPort`": ""
  "+ `JobPersonaStoragePort`": ""
  "+ `ProviderRuntimePort`": ""
  "+ `PersonaGenerationRuntimePort`": ""
  "+ `BodyTranslationPort`": ""
  style.font-size: 22
}

domainSection: {
  shape: class
  label: "domain execution control"
  "+ `ExecutionControlState` / `ExecutionControlTransition`": ""
  "+ pause / resume / retry / recover": ""
  "+ fail / cancel / complete": ""
  style.font-size: 22
}

gatewaySection -> phaseSection: phase 1..3 を直列起動する {
  style.font-size: 22
}
gatewaySection -> dtoSection: request から translation unit と policy を供給する {
  style.font-size: 22
}
phaseSection -> dtoSection: reusable terms / persona / handoff / preview を組み立てる {
  style.font-size: 22
}
phaseSection -> portSection: dictionary lookup / persona runtime / body translation を呼ぶ {
  style.font-size: 22
}
phaseSection -> domainSection: execution control の状態遷移を判定する {
  style.font-size: 22
}
portSection -> dtoSection: provider failure と sink-aware result を返す {
  style.font-size: 22
}
