layout: elk
direction: right

title: "Frontend ジョブ一覧 slice クラス図"

ui: {
  shape: package
  label: "UI"
  direction: down
  style.font-size: 22

  screen: {
    shape: class
    label: "ジョブ一覧画面 (`JobListScreen.svelte`)"
    "- 初期化を行う": ""
    style.font-size: 22
  }

  view: {
    shape: class
    label: "ジョブ一覧ビュー (`JobListView.svelte`)"
    "- refresh / retry / select を発火する": ""
    style.font-size: 22
  }
}

application: {
  shape: package
  label: "application"
  direction: down
  style.font-size: 22

  usecase: {
    shape: class
    label: "ジョブ一覧ユースケース (`JobListScreenInput` / `createJobListScreenUsecase()`)"
    "+ 初期化・再読込・再試行・選択を扱う": ""
    style.font-size: 22
  }

  store: {
    shape: class
    label: "ジョブ一覧ストア (`JobListScreenStore`)"
    "+ 読込状態と選択を保持する": ""
    style.font-size: 22
  }

  result: {
    shape: class
    label: "一覧結果 (`JobListResult`)"
    style.font-size: 22
  }
}

gateway: {
  shape: package
  label: "gateway"
  direction: down
  style.font-size: 22

  executor: {
    shape: class
    label: "ジョブ一覧 gateway (`createTauriJobListExecutor()`)"
    "- ジョブ一覧を取得する": ""
    style.font-size: 22
  }
}

ui.screen -> ui.view: 描画する {
  style.font-size: 22
}
ui.view -> application.usecase: refresh / retry / select を渡す {
  style.font-size: 22
}
ui.screen -> application.usecase: 初期化する {
  style.font-size: 22
}
application.usecase -> application.store: state を更新する {
  style.font-size: 22
}
application.usecase -> gateway.executor: 一覧取得を依頼する {
  style.font-size: 22
}
gateway.executor -> application.result: 一覧結果を返す {
  style.font-size: 22
}
application.store -> ui.view: 購読済み状態を渡す {
  style.font-size: 22
}
