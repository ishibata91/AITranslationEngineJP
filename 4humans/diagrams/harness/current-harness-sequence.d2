title: "現在のハーネス実行シーケンス"

harness: {
  shape: sequence_diagram

  caller: "呼出し元"
  entry: "Python 入口 (`run.py`)"
  runtime: "Python 実行系"
  dispatcher: "スイート調停"
  structureCheck: "構造検査"
  designCheck: "設計検査"
  executionCheck: "実行検査"
  repository: "リポジトリ状態"
  tools: "外部ツール群"

  caller -> entry: suite を指定して起動する {
    style.font-size: 22
  }
  entry -> entry: repo root を決める\n`python3` / `python` を探す {
    style.font-size: 22
  }
  entry -> runtime: Python 入口へ制御を渡す {
    style.font-size: 22
  }
  runtime -> dispatcher: suite と repo root を渡す {
    style.font-size: 22
  }
  dispatcher -> dispatcher: 実行順を決める\n`structure | design | execution | all` {
    style.font-size: 22
  }

  dispatcher -> structureCheck: `structure` を含む時に呼ぶ {
    style.font-size: 22
  }
  structureCheck -> repository: 必須 path と repo-owned link を確認する {
    style.font-size: 22
  }
  repository -> structureCheck: 存在確認結果を返す {
    style.font-size: 22
  }
  structureCheck -> dispatcher: `pass / fail` を返す {
    style.font-size: 22
  }

  dispatcher -> designCheck: `design` を含む時に呼ぶ {
    style.font-size: 22
  }
  designCheck -> repository: 契約語と semantic path を確認する {
    style.font-size: 22
  }
  repository -> designCheck: 文書確認結果を返す {
    style.font-size: 22
  }
  designCheck -> dispatcher: `pass / fail` を返す {
    style.font-size: 22
  }

  dispatcher -> executionCheck: `execution` を含む時に呼ぶ {
    style.font-size: 22
  }
  executionCheck -> repository: 実行対象と script 定義を検出する {
    style.font-size: 22
  }
  repository -> executionCheck: 実行対象一覧を返す {
    style.font-size: 22
  }
  executionCheck -> tools: `gate:execution` か標準検査を実行する {
    style.font-size: 22
  }
  tools -> executionCheck: 終了コードを返す {
    style.font-size: 22
  }
  executionCheck -> dispatcher: `pass / fail / skip` を返す {
    style.font-size: 22
  }

  dispatcher -> dispatcher: 最初の失敗で停止する {
    style.font-size: 22
  }
  dispatcher -> runtime: 全体の終了コードを返す {
    style.font-size: 22
  }
  runtime -> entry: 終了コードを伝える {
    style.font-size: 22
  }
  entry -> caller: 最終結果を返す {
    style.font-size: 22
  }
}
