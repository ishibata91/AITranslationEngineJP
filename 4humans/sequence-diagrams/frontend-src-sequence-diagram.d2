title: "Frontend `src/` sequence diagram"

jobCreateSequence: {
  shape: sequence_diagram

  user: "User"
  jobCreateView: "ジョブ作成ビュー (`JobCreateView.svelte`)"
  jobCreateScreen: "ジョブ作成画面 (`JobCreateScreen.svelte`)"
  jobCreateUsecase: "ジョブ作成ユースケース (`JobCreateScreenInput`)"
  jobCreateStore: "ジョブ作成ストア (`JobCreateScreenStore`)"
  tauriGateway: "ジョブ作成 gateway (`createTauriJobCreateExecutor()`)"
  tauriBackend: "Tauri command (`create_job`)"

  user -> jobCreateView: 入力群 (`sourceGroups`) と翻訳単位 (`translationUnits`) を入力する
  user -> jobCreateView: ジョブ作成を押す
  jobCreateView -> jobCreateScreen: 送信 event (`submit`)
  jobCreateScreen -> jobCreateUsecase: 送信する (`submit()`)
  jobCreateUsecase -> jobCreateStore: 送信中状態へ置き換える (`replaceState(nextState)`)
  jobCreateUsecase -> tauriGateway: 作成要求 (`request: JobCreateRequest`) を渡す
  tauriGateway -> tauriBackend: ジョブを作成する (`invoke(\"create_job\")`)
  tauriBackend -> tauriGateway: 作成結果 (`JobCreateResult`) を返す
  tauriGateway -> jobCreateUsecase: 解決済み結果を返す
  jobCreateUsecase -> jobCreateStore: 結果反映状態へ置き換える (`replaceState(nextState)`)
  jobCreateStore -> jobCreateView: 購読済み状態を反映する
}

jobListSequence: {
  shape: sequence_diagram

  user: "User"
  jobListScreen: "ジョブ一覧画面 (`JobListScreen.svelte`)"
  jobListUsecase: "ジョブ一覧ユースケース (`JobListScreenInput`)"
  jobListStore: "ジョブ一覧ストア (`JobListScreenStore`)"
  tauriGateway: "ジョブ一覧 gateway (`createTauriJobListExecutor()`)"
  tauriBackend: "Tauri command (`list_jobs`)"
  jobListView: "ジョブ一覧ビュー (`JobListView.svelte`)"

  user -> jobListScreen: 画面を開く
  jobListScreen -> jobListUsecase: 初期化する (`initialize()`)
  jobListUsecase -> jobListStore: 読込中にする (`setLoading()`)
  jobListUsecase -> tauriGateway: 一覧取得を依頼する
  tauriGateway -> tauriBackend: ジョブ一覧を取得する (`invoke(\"list_jobs\")`)
  tauriBackend -> tauriGateway: 一覧結果 (`JobListResult`) を返す
  tauriGateway -> jobListUsecase: 解決済み結果を返す
  jobListUsecase -> jobListStore: 読込済み状態を設定する (`setLoaded(data, selection)`)
  jobListStore -> jobListView: 購読済み状態を反映する
  user -> jobListView: ジョブID (`jobId`) を選ぶ
  jobListView -> jobListUsecase: 選択する (`select(jobId)`)
  jobListUsecase -> jobListStore: 選択状態を設定する (`setSelection(jobId)`)
}
