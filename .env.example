# Master persona provider mode: real provider calls or deterministic fake transport.
AITRANSLATIONENGINEJP_MASTER_PERSONA_AI_MODE=real

# Deterministic response used when AITRANSLATIONENGINEJP_MASTER_PERSONA_AI_MODE=fake.
AITRANSLATIONENGINEJP_MASTER_PERSONA_FAKE_RESPONSE=会話の温度を抑えつつ、相手の意図を先読みして短く返す。

# OpenAI-compatible base URL overrides.
AITRANSLATIONENGINEJP_MASTER_PERSONA_LM_STUDIO_BASE_URL=http://localhost:1234/v1
AITRANSLATIONENGINEJP_MASTER_PERSONA_XAI_BASE_URL=https://api.x.ai/v1

# Existing test-safe keyring file backend examples.
AITRANSLATIONENGINEJP_MASTER_PERSONA_SECRET_BACKEND=file
AITRANSLATIONENGINEJP_MASTER_PERSONA_SECRET_FILE_DIR=./tmp/master-persona-keyring
AITRANSLATIONENGINEJP_MASTER_PERSONA_SECRET_FILE_PASSWORD=change-me

# Existing global test mode gate.
AITRANSLATIONENGINEJP_TEST_MODE=false
