{
  "providerSelection": {
    "providerId": "gemini",
    "executionMode": "Batch",
    "runtimeSettings": {
      "retryLimit": 3,
      "maxConcurrency": 2,
      "pauseSupported": true
    }
  },
  "scenarios": [
    {
      "name": "recoverable failure retry and recovery",
      "failureCategory": "RecoverableProviderFailure",
      "transitions": [
        "Running",
        "RecoverableFailed",
        "Retrying",
        "Running",
        "Completed"
      ]
    },
    {
      "name": "pause resume and cancel",
      "failureCategory": "UserCanceled",
      "transitions": [
        "Running",
        "Paused",
        "Running",
        "Canceled"
      ]
    }
  ]
}
