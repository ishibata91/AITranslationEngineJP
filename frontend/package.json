{
  "name": "aitranslationenginejp-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:wails": "vite --host ${VITE_HOST:-127.0.0.1} --port ${VITE_PORT:-5173} --strictPort",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "npm run lint:eslint && npm run lint:types && npm run lint:exports && npm run lint:boundaries",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:types": "tsc --noEmit",
    "lint:exports": "knip --production --include-entry-exports",
    "lint:boundaries": "vitest run --config ./vitest.boundary.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.6.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "knip": "^6.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.37.0",
    "svelte-check": "^4.3.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^5.4.21",
    "vitest": "^4.1.4"
  },
  "knip": {
    "ignore": [
      "src/test/setup.ts"
    ]
  }
}
