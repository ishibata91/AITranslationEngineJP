{
  "contract_version": "2026-04-12",
  "direction": "skill-to-directing",
  "from_skill": "phase-5-test-implementation",
  "to_skill": "orchestrating-fixes",
  "purpose": "fix lane の回帰テスト設計と test 実装結果を orchestrator へ返す。",
  "required": [
    {
      "description": "review 前に固定した回帰 test。",
      "field": "failing_tests",
      "type": "string[]"
    },
    {
      "description": "追加または更新した回帰 test / fixture / helper files。",
      "field": "touched_test_files",
      "type": "string[]"
    },
    {
      "description": "再現 fixture。",
      "field": "fixtures",
      "type": "string[]"
    },
    {
      "description": "修正完了確認。",
      "field": "acceptance_checks",
      "type": "string[]"
    },
    {
      "description": "テスト実行コマンド。",
      "field": "validation_commands",
      "type": "string[]"
    }
  ],
  "optional": [
    {
      "description": "仕様未確定で残した gap。",
      "field": "open_test_gaps",
      "type": "string[]"
    }
  ],
  "must_not_change": [
    "fix scope を広げない"
  ],
  "completion_signal": [
    "orchestrator が phase-8-review に handoff できる",
    "必要な回帰 test files が review 前に用意されている"
  ]
}
