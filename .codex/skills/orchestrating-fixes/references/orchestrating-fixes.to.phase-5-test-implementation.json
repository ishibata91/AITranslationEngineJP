{
  "contract_version": "2026-04-09",
  "direction": "orchestrating-to-skill",
  "from_skill": "orchestrating-fixes",
  "to_skill": "phase-5-test-implementation",
  "purpose": "再現条件を tests / fixtures / acceptance checks / validation commands へ適用し、必要な回帰 test / fixture を先に実装させる。",
  "required": [
    {
      "description": "active fix plan。",
      "field": "active_fix_plan",
      "type": "path"
    },
    {
      "description": "再現条件と期待結果。",
      "field": "reproduction_contract",
      "type": "string[]"
    },
    {
      "description": "observed facts と fix scope。",
      "field": "analysis_summary",
      "type": "object"
    }
  ],
  "optional": [
    {
      "description": "優先する test layer。",
      "field": "preferred_test_layer",
      "type": "string"
    }
  ],
  "must_not_change": [
    "test / fixture 以外の実装修正を混ぜない",
    "再現条件にない新しい要件解釈を足さない"
  ],
  "completion_signal": [
    "failing_tests と acceptance_checks が fix scope に結び付いている",
    "touched_test_files が定義されている"
  ]
}
