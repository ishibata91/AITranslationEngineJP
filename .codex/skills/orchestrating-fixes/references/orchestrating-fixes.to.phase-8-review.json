{
  "contract_version": "2026-04-12",
  "direction": "directing-to-skill",
  "from_skill": "orchestrating-fixes",
  "to_skill": "phase-8-review",
  "purpose": "fix 差分 review に必要な根拠を implementation review phase へ渡す。",
  "required": [
    {
      "description": "active fix plan。",
      "field": "active_fix_plan",
      "type": "path"
    },
    {
      "description": "確認対象の accepted fix scope。",
      "field": "accepted_fix_scope",
      "type": "string[]"
    },
    {
      "description": "何をどう直したか。",
      "field": "change_summary",
      "type": "string[]"
    },
    {
      "description": "照合すべき plan / spec / tests。",
      "field": "spec_refs",
      "type": "string[]"
    },
    {
      "description": "checks 実行結果。",
      "field": "validation_evidence",
      "type": "string[]"
    }
  ],
  "optional": [
    {
      "description": "review 時に特に見る論点。",
      "field": "known_risks",
      "type": "string[]"
    }
  ],
  "must_not_change": [
    "review scope を 仕様逸脱、例外処理、リソース解放、テスト不足の 4 観点以外へ広げない"
  ],
  "completion_signal": [
    "reviewer が fix plan 基準で pass / reroute を判定できる"
  ]
}
