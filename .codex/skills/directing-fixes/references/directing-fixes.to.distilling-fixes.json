{
  "contract_version": "2026-03-28",
  "direction": "directing-to-skill",
  "from_skill": "directing-fixes",
  "to_skill": "distilling-fixes",
  "purpose": "bugfix 入口情報から最小限の repo 文脈を探索させる。",
  "required": [
    {
      "description": "不具合の要約。",
      "field": "bug_summary",
      "type": "string"
    },
    {
      "description": "作業中の fix plan。",
      "field": "active_fix_plan",
      "type": "path"
    },
    {
      "description": "既知の再現条件または未再現情報。",
      "field": "known_reproduction",
      "type": "string[]"
    },
    {
      "description": "探索の起点として渡す code / docs / tests の候補。",
      "field": "seed_area",
      "type": "string[]"
    }
  ],
  "optional": [
    {
      "description": "ユーザー影響や失敗条件。",
      "field": "reported_impact",
      "type": "string[]"
    }
  ],
  "must_not_change": [
    "推測を事実として固定しない"
  ],
  "completion_signal": [
    "known facts と open gaps を分離して返せる",
    "required reading が入口 path の単純再掲ではなく次工程の探索コストを下げている"
  ]
}
