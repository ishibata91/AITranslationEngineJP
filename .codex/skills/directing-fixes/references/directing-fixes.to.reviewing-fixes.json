{
  "contract_version": "2026-03-28",
  "direction": "directing-to-skill",
  "from_skill": "directing-fixes",
  "to_skill": "reviewing-fixes",
  "purpose": "fix 差分 review に必要な根拠を渡す。",
  "required": [
    {
      "description": "何をどう直したか。",
      "field": "change_summary",
      "type": "string[]"
    },
    {
      "description": "照合すべき plan / spec / tests。",
      "field": "spec_refs",
      "type": "string[]"
    },
    {
      "description": "checks 実行結果。",
      "field": "validation_evidence",
      "type": "string[]"
    }
  ],
  "optional": [
    {
      "description": "review 時に特に見る論点。",
      "field": "suspected_residual_risk",
      "type": "string[]"
    }
  ],
  "must_not_change": [
    "review scope を 4 観点以外へ広げない"
  ],
  "completion_signal": [
    "reviewer が pass / reroute を判定できる"
  ]
}
