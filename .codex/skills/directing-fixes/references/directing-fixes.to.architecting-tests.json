{
  "contract_version": "2026-03-28",
  "direction": "directing-to-skill",
  "from_skill": "directing-fixes",
  "to_skill": "architecting-tests",
  "purpose": "fix lane 向け回帰テスト契約を固定し、必要な回帰 test / fixture を先に実装させる。",
  "required": [
    {
      "description": "fix plan。",
      "field": "active_fix_plan",
      "type": "path"
    },
    {
      "description": "再現条件と期待結果。",
      "field": "reproduction_contract",
      "type": "string[]"
    },
    {
      "description": "observed facts と fix scope。",
      "field": "analysis_summary",
      "type": "object"
    }
  ],
  "optional": [
    {
      "description": "unit / integration / acceptance の優先。",
      "field": "preferred_test_layer",
      "type": "string"
    }
  ],
  "must_not_change": [
    "test / fixture 以外の実装修正を混ぜない"
  ],
  "completion_signal": [
    "failing_tests と acceptance_checks が fix scope に結び付いている",
    "touched_test_files が定義されている"
  ]
}
