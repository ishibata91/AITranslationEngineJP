{
  "contract_version": "2026-03-28",
  "direction": "skill-to-directing",
  "from_skill": "implementing-fixes",
  "to_skill": "orchestrating-fixes",
  "purpose": "fix 実装結果を review と closeout に引き渡す。",
  "required": [
    {
      "description": "変更した file。",
      "field": "changed_files",
      "type": "string[]"
    },
    {
      "description": "実行した checks。",
      "field": "checks_run",
      "type": "string[]"
    },
    {
      "description": "checks 結果要約。",
      "field": "check_results",
      "type": "string[]"
    }
  ],
  "optional": [
    {
      "description": "残留リスク。",
      "field": "residual_risk",
      "type": "string[]"
    },
    {
      "description": "一時 logging の除去完了。",
      "field": "temporary_logging_cleanup_done",
      "type": "boolean"
    }
  ],
  "must_not_change": [
    "review 判定を自分で確定しない"
  ],
  "completion_signal": [
    "orchestrator が reviewing-fixes に handoff できる差分証跡がある"
  ]
}
