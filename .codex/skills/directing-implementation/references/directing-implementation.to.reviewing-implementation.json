{
  "contract_version": "2026-03-28",
  "direction": "directing-to-skill",
  "from_skill": "directing-implementation",
  "to_skill": "reviewing-implementation",
  "purpose": "実装差分 review に必要な証跡を単発 review skill へ渡す。",
  "required": [
    {
      "description": "何を変えたかの短い要約。",
      "field": "change_summary",
      "type": "string[]"
    },
    {
      "description": "照合すべき docs / plan / tests。",
      "field": "spec_refs",
      "type": "string[]"
    },
    {
      "description": "checks 実行結果。",
      "field": "validation_evidence",
      "type": "string[]"
    }
  ],
  "optional": [
    {
      "description": "review 時に注意すべき論点。",
      "field": "known_risks",
      "type": "string[]"
    }
  ],
  "must_not_change": [
    "review scope を 4 観点以外へ広げない"
  ],
  "completion_signal": [
    "reviewer が pass / reroute を判定できる"
  ]
}
