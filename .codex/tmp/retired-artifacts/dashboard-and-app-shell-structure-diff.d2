direction: right

classes: {
  added: {
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    style.font-color: "#1b5e20"
    style.stroke-width: 2
  }
  removed: {
    style.fill: "#ffebee"
    style.stroke: "#c62828"
    style.font-color: "#8e0000"
    style.stroke-width: 2
  }
}

title: "dashboard-and-app-shell proposal diff"

legend: {
  label: "凡例"
  shape: rectangle
  style.stroke: "#9e9e9e"

  add: "緑 = 追加 / 置換後"
  add.class: added

  remove: "赤 = 現状 / 置換前"
  remove.class: removed
}

current: {
  label: "現状 component view"
  direction: down
  style.stroke: "#c62828"
  style.stroke-width: 2
  style.fill: "#fff8f8"
  style.font-color: "#5f1616"

  view_package: {
    label: "package: View"
    direction: down
    style.stroke: "#c62828"
    style.stroke-dash: 4
    style.fill: "#fff1f1"
    style.font-color: "#5f1616"

    app: {
      shape: class
      class: removed
      label: "frontend/src/ui/App.svelte"
      +shellState: ShellState
      +createShellState(): ShellState
      +render(): "AppShell(title)"
    }

    shell: {
      shape: class
      class: removed
      label: "frontend/src/ui/views/AppShell.svelte"
      +title: string
      +renderHero(): void
      -currentLocationLabel: none
      -navigationSurface: none
      -contentOutlet: none
    }
  }

  store_package: {
    label: "package: Store"
    direction: down
    style.stroke: "#c62828"
    style.stroke-dash: 4
    style.fill: "#fff1f1"
    style.font-color: "#5f1616"

    state: {
      shape: class
      class: removed
      label: "frontend/src/ui/stores/shell-state.ts"
      +title: string = "Architecture Skeleton"
      +createShellState(): ShellState
      -routeRegistry: none
      -currentRoute: none
    }
  }

  view_package.app -> store_package.state: "shellState を生成" {
    style.stroke: "#c62828"
  }
  view_package.app -> view_package.shell: "title prop のみを渡す" {
    style.stroke: "#c62828"
  }
}

proposal: {
  label: "提案 component class view"
  direction: down
  style.stroke: "#2e7d32"
  style.stroke-width: 2
  style.fill: "#f7fff7"
  style.font-color: "#1b5e20"

  view_package: {
    label: "package: View"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    app: {
      shape: class
      class: added
      label: "frontend/src/ui/App.svelte"
      +shellState: ShellState
      +createShellState(): ShellState
      +render(): "AppShell(shellState)"
    }

    shell: {
      shape: class
      class: added
      label: "frontend/src/ui/views/AppShell.svelte"
      +shellState: ShellState
      +renderShellFrame(): void
      +renderCurrentLocation(): void
      +renderNavigation(): void
      +renderCurrentView(): void
    }

    dashboard_view: {
      shape: class
      class: added
      label: "DashboardView responsibilities"
      +entryCards: five RouteCard entries
      +defaultOnStartup: true
      +activeCardRoute: RouteId
      +openDestination(route: RouteId): void
      +excludeJobListAndProgressSummary(): void
    }

    placeholder_view: {
      shape: class
      class: added
      label: "PlaceholderView responsibilities"
      +pageLabel: string
      +statusText: "準備中"
      +showNavigationBackstop(): void
      +renderNonDashboardDestination(): void
    }

    navigation_surface: {
      shape: class
      class: added
      label: "Navigation / current-location surface"
      +destinations: five RouteId destinations
      +activeRoute: RouteId
      +currentLocationChip: string
      +selectDestination(route: RouteId): void
    }
  }

  store_package: {
    label: "package: Store"
    direction: down
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
    style.fill: "#eef9ef"
    style.font-color: "#1b5e20"

    state: {
      shape: class
      class: added
      label: "frontend/src/ui/stores/shell-state.ts"
      +routeOrder: RouteId list
      +currentRoute: RouteId = dashboard
      +currentPageLabel: string
      +currentLocationLabel: string
      +placeholderStatus: string
      +navigate(destination: RouteId): void
      +getRouteMeta(route: RouteId): RouteMeta
    }
  }

  view_package.app -> store_package.state: "shell state を生成" {
    style.stroke: "#2e7d32"
  }
  view_package.app -> view_package.shell: "shellState を渡す" {
    style.stroke: "#2e7d32"
  }
  store_package.state -> view_package.shell: "現在地と描画条件を供給" {
    style.stroke: "#2e7d32"
  }
  view_package.shell -> view_package.navigation_surface: "共通 header / nav を描画" {
    style.stroke: "#2e7d32"
  }
  view_package.shell -> view_package.dashboard_view: "route = dashboard のとき描画" {
    style.stroke: "#2e7d32"
  }
  view_package.shell -> view_package.placeholder_view: "route != dashboard のとき描画" {
    style.stroke: "#2e7d32"
  }
  view_package.navigation_surface -> store_package.state: "navigate(destination)" {
    style.stroke: "#2e7d32"
  }
  view_package.dashboard_view -> store_package.state: "openDestination(route)" {
    style.stroke: "#2e7d32"
  }
  store_package.state -> view_package.navigation_surface: "activeRoute / currentLocationLabel" {
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
  }
  store_package.state -> view_package.dashboard_view: "entryCards / activeCardRoute" {
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
  }
  store_package.state -> view_package.placeholder_view: "pageLabel / placeholderStatus" {
    style.stroke: "#2e7d32"
    style.stroke-dash: 4
  }
}
